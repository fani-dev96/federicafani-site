---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Pagina non trovata — Federica Fanì">
  <section style="min-height: calc(100vh - 68px); display: flex; align-items: center; justify-content: center; text-align: center; padding: 40px 20px;">
    <div>
      <p style="font-family: 'Cormorant Garamond', serif; font-size: 120px; font-weight: 300; color: var(--blue-light); line-height: 1;">404</p>
      <h1 style="font-family: 'Cormorant Garamond', serif; font-weight: 300; color: var(--blue-dark); margin-bottom: 16px;">Pagina non trovata</h1>
      <p style="color: var(--blue-mid); margin-bottom: 32px;">Questa pagina non esiste, ma il resto del sito sì.</p>
      <a href="/" class="btn btn-primary">Torna alla home</a>
    </div>
  </section>
</Layout>

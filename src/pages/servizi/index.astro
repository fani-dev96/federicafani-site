---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Servizi — Federica Fanì"
  description="Social media management, sviluppo app, data privacy e project management. Cose concrete, fatte con cura."
>

  <!-- HERO -->
  <section class="svc-hero">
    <div class="svc-hero-inner">
      <div class="hero-eyebrow reveal">
        <span class="eyebrow-line"></span>
        <span class="eyebrow">Cosa faccio</span>
      </div>
      <h1 class="reveal reveal-delay-1">Servizi</h1>
      <p class="svc-hero-sub reveal reveal-delay-2">
        Social media, app, fotografia. Cose concrete, fatte con cura.
      </p>
    </div>
  </section>

  <!-- SERVIZI ATTIVI -->
  <section class="section">
    <div class="sec-header">
      <div class="sec-header-left">
        <span class="eyebrow reveal">Disponibili ora</span>
        <h2 class="reveal reveal-delay-1">Posso aiutarti con</h2>
      </div>
    </div>

    <div class="svc-cards">
      <a href="/servizi/smm" class="svc-card-big reveal">
        <div class="svc-card-big-left">
          <div class="svc-ico">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
          </div>
          <div>
            <div class="svc-card-title">Social Media Management</div>
            <div class="svc-card-desc">Strategia, contenuti, foto e gestione profili per brand e locali che vogliono una presenza autentica. Non solo bella da guardare.</div>
            <div class="svc-tags">
              <span class="svc-tag">Instagram</span>
              <span class="svc-tag">Facebook</span>
              <span class="svc-tag">TikTok</span>
              <span class="svc-tag">Fotografia</span>
              <span class="svc-tag">Analytics</span>
            </div>
          </div>
        </div>
        <div class="svc-card-big-right">
          <div class="svc-price-preview">
            <div class="price-from">da</div>
            <div class="price-val">€400</div>
            <div class="price-period">/mese</div>
          </div>
          <span class="svc-arrow-big">→</span>
        </div>
      </a>

      <a href="/servizi/app-dev" class="svc-card-big reveal reveal-delay-1">
        <div class="svc-card-big-left">
          <div class="svc-ico">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
          </div>
          <div>
            <div class="svc-card-title">App & SaaS Development</div>
            <div class="svc-card-desc">App Android native in Flutter, web app e piccoli SaaS. Dal concept al deploy, con approccio artigianale: ogni progetto pensato da zero.</div>
            <div class="svc-tags">
              <span class="svc-tag">Flutter</span>
              <span class="svc-tag">Android</span>
              <span class="svc-tag">Firebase</span>
              <span class="svc-tag">Web App</span>
              <span class="svc-tag">SaaS</span>
            </div>
          </div>
        </div>
        <div class="svc-card-big-right">
          <div class="svc-price-preview">
            <div class="price-from">da</div>
            <div class="price-val">€3.000</div>
            <div class="price-period">a progetto</div>
          </div>
          <span class="svc-arrow-big">→</span>
        </div>
      </a>
    </div>
  </section>

  <!-- SERVIZI IN ARRIVO -->
  <div class="section-dark">
    <section class="section">
      <div class="sec-header">
        <div class="sec-header-left">
          <span class="eyebrow eyebrow-light reveal">In arrivo</span>
          <h2 class="sec-title-light reveal reveal-delay-1">Prossimamente</h2>
        </div>
      </div>
      <p class="coming-soon-sub reveal reveal-delay-2">Certificazioni in corso, lancio previsto entro il 2027.</p>

      <div class="coming-grid">
        <div class="coming-card reveal reveal-delay-1">
          <div class="coming-ico">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <div class="coming-title">Data Privacy & GRC</div>
          <div class="coming-desc">Consulenza GDPR, compliance digitale e gestione del rischio. Con CIPP/E in corso — la combo privacy + SMM è ancora rara sul mercato.</div>
          <div class="coming-badge">CIPP/E in corso</div>
        </div>

        <div class="coming-card reveal reveal-delay-2">
          <div class="coming-ico">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          </div>
          <div class="coming-title">Project Management</div>
          <div class="coming-desc">Coordinamento progetti digitali, gestione processi e team remoti. Percorso Google PM Certificate → CAPM → PMP in sviluppo.</div>
          <div class="coming-badge">Google PM Certificate in corso</div>
        </div>
      </div>
    </section>
  </div>

  <!-- PERCHÉ LAVORARE CON ME -->
  <section class="section why-section">
    <div class="sec-header">
      <div class="sec-header-left">
        <span class="eyebrow reveal">Perché scegliermi</span>
        <h2 class="reveal reveal-delay-1">Il mio approccio</h2>
      </div>
    </div>

    <div class="why-grid">
      <div class="why-item reveal">
        <div class="why-num">01</div>
        <div class="why-title">Autenticità prima di tutto</div>
        <div class="why-desc">I social sono pieni di contenuti. Quello che manca è la personalità. Parto sempre dalla domanda: cosa rende unico questo brand? Poi costruiamo tutto attorno a quella risposta.</div>
      </div>
      <div class="why-item reveal reveal-delay-1">
        <div class="why-num">02</div>
        <div class="why-title">Stack multiplo, visione unica</div>
        <div class="why-desc">SMM, sviluppo, fotografia e privacy nello stesso profilo. Non devi coordinare tre persone diverse: ho una visione integrata del digitale.</div>
      </div>
      <div class="why-item reveal reveal-delay-2">
        <div class="why-num">03</div>
        <div class="why-title">4 lingue di lavoro</div>
        <div class="why-desc">Italiano, inglese, spagnolo e francese. Utile sia per clienti internazionali che per contenuti multilingue senza affidarsi a traduttori esterni.</div>
      </div>
      <div class="why-item reveal reveal-delay-3">
        <div class="why-num">04</div>
        <div class="why-title">Approccio artigianale</div>
        <div class="why-desc">Lavoro come freelance singola, non come agenzia. Ogni progetto riceve attenzione diretta, senza account manager in mezzo e senza soluzioni preconfezionate.</div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <div class="section-dark">
    <section class="section cta-section">
      <div class="cta-inner">
        <span class="eyebrow eyebrow-light reveal">Parliamo</span>
        <h2 class="sec-title-light reveal reveal-delay-1">Hai un progetto in mente?</h2>
        <p class="cta-sub reveal reveal-delay-2">Non mordono, i messaggi. Scrivimi per collaborazioni, preventivi, o anche solo per capire se posso aiutarti.</p>
        <div class="cta-btns reveal reveal-delay-3">
          <a href="/contatti" class="btn btn-gold">Scrivimi</a>
          <a href="/portfolio" class="btn btn-outline-light">Guarda il portfolio</a>
        </div>
      </div>
    </section>
  </div>

</Layout>

<style>
.svc-hero {
  padding: clamp(48px, 6vw, 80px) clamp(20px, 5vw, 80px) clamp(32px, 4vw, 56px);
  background: var(--blue-pale);
}

.svc-hero-inner {
  max-width: 1200px;
  margin: 0 auto;
}

.hero-eyebrow {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 16px;
}

.eyebrow-line {
  width: 32px;
  height: 1px;
  background: var(--blue);
  flex-shrink: 0;
}

.svc-hero h1 {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(40px, 6vw, 72px);
  font-weight: 300;
  color: var(--blue-dark);
  margin-bottom: 16px;
  line-height: 1.1;
}

.svc-hero-sub {
  font-size: 16px;
  color: var(--blue-mid);
  font-style: italic;
  font-family: 'Cormorant Garamond', serif;
}

/* SERVICE CARDS */
.svc-cards {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.svc-card-big {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 32px;
  background: var(--white);
  border: 0.5px solid rgba(43,79,216,0.15);
  border-radius: var(--r-lg);
  padding: 28px 32px;
  text-decoration: none;
  transition: all 0.25s ease;
}

.svc-card-big:hover {
  border-color: var(--blue);
  box-shadow: 0 4px 24px rgba(43,79,216,0.1);
  transform: translateY(-2px);
}

.svc-card-big-left {
  display: flex;
  align-items: flex-start;
  gap: 20px;
  flex: 1;
}

.svc-ico {
  width: 48px;
  height: 48px;
  border-radius: var(--r-md);
  background: var(--blue-light);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--blue);
  flex-shrink: 0;
}

.svc-card-title {
  font-size: 18px;
  font-weight: 500;
  color: var(--blue-dark);
  margin-bottom: 8px;
  font-family: 'Cormorant Garamond', serif;
}

.svc-card-desc {
  font-size: 14px;
  color: var(--blue-mid);
  line-height: 1.7;
  margin-bottom: 14px;
  max-width: 520px;
}

.svc-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

.svc-tag {
  font-size: 11px;
  font-weight: 500;
  padding: 3px 10px;
  border-radius: 20px;
  background: var(--blue-light);
  color: var(--blue);
  border: 0.5px solid rgba(43,79,216,0.2);
}

.svc-card-big-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 12px;
  flex-shrink: 0;
}

.svc-price-preview {
  text-align: right;
}

.price-from {
  font-size: 11px;
  color: var(--blue-mid);
  letter-spacing: 0.06em;
}

.price-val {
  font-family: 'Cormorant Garamond', serif;
  font-size: 32px;
  font-weight: 400;
  color: var(--blue);
  line-height: 1;
}

.price-period {
  font-size: 12px;
  color: var(--blue-mid);
  margin-top: 2px;
}

.svc-arrow-big {
  font-size: 20px;
  color: var(--blue);
  transition: transform 0.2s ease;
}

.svc-card-big:hover .svc-arrow-big { transform: translateX(5px); }

/* COMING SOON */
.coming-soon-sub {
  font-size: 14px;
  color: var(--azure);
  margin-bottom: 28px;
  font-style: italic;
  font-family: 'Cormorant Garamond', serif;
}

.coming-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}

.coming-card {
  background: rgba(43,79,216,0.1);
  border: 0.5px solid rgba(123,167,232,0.2);
  border-radius: var(--r-lg);
  padding: 24px;
  opacity: 0.8;
}

.coming-ico {
  width: 40px;
  height: 40px;
  border-radius: var(--r-md);
  background: rgba(43,79,216,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--azure);
  margin-bottom: 14px;
}

.coming-title {
  font-size: 16px;
  font-weight: 500;
  color: var(--white);
  margin-bottom: 8px;
  font-family: 'Cormorant Garamond', serif;
}

.coming-desc {
  font-size: 13px;
  color: var(--azure);
  line-height: 1.7;
  margin-bottom: 14px;
}

.coming-badge {
  display: inline-block;
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 0.06em;
  background: rgba(232,201,122,0.2);
  color: var(--gold);
  border: 0.5px solid rgba(232,201,122,0.3);
  padding: 4px 10px;
  border-radius: 20px;
}

/* WHY */
.why-section { padding-top: clamp(48px, 6vw, 80px); padding-bottom: clamp(48px, 6vw, 80px); }

.why-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 32px 48px;
}

.why-num {
  font-family: 'Cormorant Garamond', serif;
  font-size: 48px;
  font-weight: 300;
  color: var(--blue-light);
  line-height: 1;
  margin-bottom: 8px;
}

.why-title {
  font-size: 16px;
  font-weight: 500;
  color: var(--blue-dark);
  margin-bottom: 8px;
}

.why-desc {
  font-size: 14px;
  color: var(--blue-mid);
  line-height: 1.75;
}

/* CTA */
.cta-section { text-align: center; }
.cta-section .eyebrow { display: block; margin-bottom: 8px; }
.cta-section h2 { margin-bottom: 16px; }

.cta-sub {
  font-size: 15px;
  color: var(--azure);
  max-width: 480px;
  margin: 0 auto 32px;
  line-height: 1.75;
}

.cta-btns {
  display: flex;
  gap: 12px;
  justify-content: center;
  flex-wrap: wrap;
}

/* RESPONSIVE */
@media (max-width: 768px) {
  .svc-card-big { flex-direction: column; align-items: flex-start; }
  .svc-card-big-right { flex-direction: row; align-items: center; width: 100%; justify-content: space-between; }
  .coming-grid { grid-template-columns: 1fr; }
  .why-grid { grid-template-columns: 1fr; gap: 24px; }
}
</style>

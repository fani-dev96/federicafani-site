---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Federica Fanì — Social Media Manager, Sviluppatrice, Fotografa"
  description="Social media manager, sviluppatrice, fotografa, esaurita. I progetti migliori nascono dall'intersezione di queste 4 cose."
>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-content">
      <div class="hero-left">
        <div class="hero-eyebrow reveal">
          <span class="eyebrow-line"></span>
          <span class="eyebrow">Social Media Manager · App Developer · Fotografa · Roma</span>
        </div>

        <h1 class="hero-headline reveal reveal-delay-1">
          Pianoforte e batteria.<br>
          Vinili e codice.<br>
          <em>Gli opposti non si escludono : si moltiplicano.</em>
        </h1>

        <p class="hero-sub reveal reveal-delay-2">
          Social media manager, sviluppatrice, fotografa, esaurita.<br>I progetti migliori? Nascono dall'intersezione di queste 4 cose, anche se forse la quarta è solo un risultato delle prime tre.
        </p>

        <div class="hero-ctas reveal reveal-delay-3">
          <a href="/servizi" class="btn btn-primary">Scopri i servizi</a>
          <a href="/portfolio" class="btn btn-outline">Guarda il portfolio</a>
        </div>

        <div class="hero-stats reveal reveal-delay-4">
          <div class="stat">
            <div class="stat-val">3+</div>
            <div class="stat-label">Anni di esperienza</div>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <div class="stat-val">IT · EN · ES</div>
            <div class="stat-label">Lingue di lavoro</div>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <div class="stat-val">Roma</div>
            <div class="stat-label">E remoto ovunque</div>
          </div>
        </div>
      </div>

      <div class="hero-right reveal reveal-delay-2">
        <div class="hero-img-wrap">
          <div class="hero-deco-circle"></div>
          <div class="hero-img">
            <img src="/images/foto_2.jpg" alt="Federica Fanì" loading="eager" style="object-position: center top;" />
          </div>
          <div class="hero-badge">
            <div class="badge-dot"></div>
            <div class="badge-text">
              <strong>Disponibile per nuovi progetti</strong>
              <span>open to work</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVIZI PREVIEW -->
  <div class="section-dark">
    <section class="section">
      <div class="sec-header">
        <div class="sec-header-left">
          <span class="eyebrow eyebrow-light reveal">Cosa faccio</span>
          <h2 class="sec-title-light reveal reveal-delay-1">Servizi</h2>
        </div>
        <a href="/servizi" class="sec-link sec-link-light reveal">Scopri tutti <span>→</span></a>
      </div>

      <div class="svc-grid">
        <a href="/servizi/smm" class="svc-card reveal">
          <div class="svc-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
          </div>
          <div class="svc-name">Social Media Management</div>
          <div class="svc-desc">Social media, app, fotografia. Cose concrete, fatte con cura.</div>
          <span class="svc-arrow">→</span>
        </a>

        <a href="/servizi/app-dev" class="svc-card reveal reveal-delay-1">
          <div class="svc-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
          </div>
          <div class="svc-name">App & SaaS Development</div>
          <div class="svc-desc">Cose concrete, fatte con cura.</div>
          <span class="svc-arrow">→</span>
        </a>

        <div class="svc-card svc-soon reveal reveal-delay-2">
          <div class="svc-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <div class="svc-name">Data Privacy & GRC</div>
          <div class="svc-desc">Compliance digitale e gestione del rischio.</div>
          <span class="soon-badge">In arrivo</span>
        </div>

        <div class="svc-card svc-soon reveal reveal-delay-3">
          <div class="svc-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          </div>
          <div class="svc-name">Project Management</div>
          <div class="svc-desc">Coordinamento processi e gestione progetti digitali.</div>
          <span class="soon-badge">In arrivo</span>
        </div>
      </div>
    </section>
  </div>

  <!-- CHI SONO PREVIEW -->
  <section class="section about-preview">
    <div class="about-grid">
      <div class="about-text">
        <span class="eyebrow reveal">Chi sono</span>
        <h2 class="reveal reveal-delay-1">Pescara, Macerata, Roma. Pianoforte, batteria, vinili, codice.</h2>
        <p class="reveal reveal-delay-2">La versione lunga è qui.</p>
        <a href="/chi-sono" class="btn btn-outline reveal reveal-delay-3">Scopri di più</a>
      </div>
      <div class="about-facts reveal reveal-delay-1">
        <div class="fact-item">
          <span class="fact-num">19</span>
          <span class="fact-label">Tatuaggi, perlopiù musicali</span>
        </div>
        <div class="fact-item">
          <span class="fact-num">4</span>
          <span class="fact-label">Lingue parlate</span>
        </div>
        <div class="fact-item">
          <span class="fact-num">∞</span>
          <span class="fact-label">Vinili da collezionare</span>
        </div>
      </div>
    </div>
  </section>

  <!-- FORMAZIONE PREVIEW -->
  <div class="section-dark">
    <section class="section">
      <div class="sec-header">
        <div class="sec-header-left">
          <span class="eyebrow eyebrow-light reveal">Formazione</span>
          <h2 class="sec-title-light reveal reveal-delay-1">Certificazioni</h2>
        </div>
        <a href="/formazione" class="sec-link sec-link-light reveal">Vedi tutte <span>→</span></a>
      </div>
      <p class="cert-preview-text reveal reveal-delay-1">Quello che so fare, ho un pezzo di carta che lo certifica. Quasi sempre.</p>
      <div class="cert-pills reveal reveal-delay-2">
        <span class="cert-pill">Learnn</span>
        <span class="cert-pill">Carriere.it</span>
        <span class="cert-pill">Coursera</span>
        <span class="cert-pill">Google Skillshop</span>
        <span class="cert-pill">Meta Blueprint</span>
        <span class="cert-pill">HubSpot Academy</span>
      </div>
    </section>
  </div>

  <!-- GALLERIA PREVIEW -->
  <section class="section gallery-preview">
    <div class="sec-header">
      <div class="sec-header-left">
        <span class="eyebrow reveal">Galleria</span>
        <h2 class="reveal reveal-delay-1">Fotografia</h2>
      </div>
      <a href="/galleria" class="sec-link reveal">Vedi tutto <span>→</span></a>
    </div>
    <p class="gallery-sub reveal reveal-delay-1">Concerti, club, persone. Scattate con una Nikon e tanta pazienza per la luce giusta.</p>
    <div class="gallery-grid reveal reveal-delay-2">
      <div class="gallery-cell gallery-cell-large">
        <img src="/foto/foto1.jpg" alt="Fotografia" loading="lazy" />
      </div>
      <div class="gallery-cell">
        <img src="/foto/foto2.jpg" alt="Fotografia" loading="lazy" />
      </div>
      <div class="gallery-cell">
        <img src="/foto/foto3.jpg" alt="Fotografia" loading="lazy" />
      </div>
      <div class="gallery-cell">
        <img src="/foto/foto4.jpg" alt="Fotografia" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- CONTATTI PREVIEW -->
  <div class="section-dark">
    <section class="section contact-preview">
      <div class="contact-inner">
        <span class="eyebrow eyebrow-light reveal">Parliamo</span>
        <h2 class="sec-title-light reveal reveal-delay-1">Hai un progetto in mente?</h2>
        <p class="contact-sub reveal reveal-delay-2">Non mordono, i messaggi. Scrivimi per collaborazioni, progetti, o anche solo per consigliarmi un disco.</p>
        <a href="/contatti" class="btn btn-gold reveal reveal-delay-3">Scrivimi</a>
      </div>
    </section>
  </div>

</Layout>

<style>
/* HERO */
.hero {
  min-height: calc(100vh - 68px);
  display: flex;
  align-items: center;
  padding: clamp(48px, 6vw, 80px) clamp(20px, 5vw, 80px);
  background: var(--blue-pale);
}

.hero-content {
  max-width: 1200px;
  margin: 0 auto;
  width: 100%;
  display: grid;
  grid-template-columns: 1fr 420px;
  gap: clamp(40px, 6vw, 80px);
  align-items: center;
}

.hero-eyebrow {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 24px;
}

.eyebrow-line {
  width: 32px;
  height: 1px;
  background: var(--blue);
  flex-shrink: 0;
}

.hero-headline {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(32px, 4.5vw, 58px);
  font-weight: 300;
  line-height: 1.15;
  color: var(--blue-dark);
  margin-bottom: 24px;
  letter-spacing: -0.01em;
}

.hero-headline em {
  font-style: italic;
  color: var(--blue);
}

.hero-sub {
  font-size: clamp(14px, 1.2vw, 16px);
  color: var(--blue-mid);
  line-height: 1.75;
  max-width: 480px;
  margin-bottom: 32px;
}

.hero-ctas {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  margin-bottom: 40px;
}

.hero-stats {
  display: flex;
  align-items: center;
  gap: 24px;
  padding-top: 32px;
  border-top: 0.5px solid rgba(43,79,216,0.15);
}

.stat-val {
  font-size: clamp(18px, 1.8vw, 22px);
  font-weight: 500;
  color: var(--blue);
  font-family: 'Cormorant Garamond', serif;
}

.stat-label {
  font-size: 10px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--blue-mid);
  margin-top: 3px;
}

.stat-divider {
  width: 1px;
  height: 36px;
  background: rgba(43,79,216,0.15);
  flex-shrink: 0;
}

.hero-img-wrap { position: relative; }

.hero-deco-circle {
  position: absolute;
  top: -24px;
  right: -24px;
  width: 140px;
  height: 140px;
  border-radius: 50%;
  background: var(--blue-light);
  z-index: 0;
}

.hero-img {
  position: relative;
  z-index: 1;
  border-radius: var(--r-lg);
  overflow: hidden;
  aspect-ratio: 4/5;
  border: 0.5px solid rgba(43,79,216,0.15);
}

.hero-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.hero-badge {
  position: absolute;
  bottom: 24px;
  left: -20px;
  z-index: 2;
  background: var(--blue-dark);
  border-radius: var(--r-md);
  padding: 12px 16px;
  display: flex;
  align-items: center;
  gap: 10px;
  border: 0.5px solid rgba(123,167,232,0.2);
}

.badge-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--gold);
  flex-shrink: 0;
}

.badge-text strong {
  display: block;
  font-size: 12px;
  font-weight: 500;
  color: var(--white);
}

.badge-text span {
  font-size: 10px;
  color: var(--azure);
}

/* SERVICES */
.svc-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14px;
}

.svc-card {
  background: rgba(43,79,216,0.1);
  border: 0.5px solid rgba(123,167,232,0.2);
  border-radius: var(--r-lg);
  padding: 22px;
  display: flex;
  flex-direction: column;
  gap: 10px;
  transition: background 0.2s ease, transform 0.2s ease;
  text-decoration: none;
}

.svc-card:not(.svc-soon):hover {
  background: rgba(43,79,216,0.2);
  transform: translateY(-3px);
}

.svc-card.svc-soon { opacity: 0.55; cursor: default; }

.svc-icon {
  width: 40px;
  height: 40px;
  border-radius: var(--r-sm);
  background: rgba(43,79,216,0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--azure);
}

.svc-name {
  font-size: 14px;
  font-weight: 500;
  color: var(--white);
}

.svc-desc {
  font-size: 12px;
  color: var(--azure);
  line-height: 1.6;
  flex: 1;
}

.svc-arrow {
  font-size: 16px;
  color: var(--azure);
  margin-top: auto;
  transition: transform 0.2s ease;
}

.svc-card:hover .svc-arrow { transform: translateX(4px); }

.soon-badge {
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 0.06em;
  background: rgba(43,79,216,0.3);
  color: var(--azure);
  padding: 3px 9px;
  border-radius: 20px;
  align-self: flex-start;
}

/* ABOUT PREVIEW */
.about-preview { padding-top: clamp(48px, 6vw, 80px); padding-bottom: clamp(48px, 6vw, 80px); }

.about-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: clamp(40px, 6vw, 80px);
  align-items: center;
}

.about-text { display: flex; flex-direction: column; gap: 16px; }
.about-text h2 { color: var(--blue-dark); }
.about-text p { color: var(--blue-mid); font-size: 15px; }

.about-facts {
  display: flex;
  flex-direction: column;
  gap: 24px;
  padding: 32px;
  background: var(--blue-light);
  border-radius: var(--r-lg);
  border: 0.5px solid rgba(43,79,216,0.15);
}

.fact-item { display: flex; align-items: baseline; gap: 16px; }

.fact-num {
  font-family: 'Cormorant Garamond', serif;
  font-size: 42px;
  font-weight: 300;
  color: var(--blue);
  line-height: 1;
  min-width: 60px;
}

.fact-label {
  font-size: 13px;
  color: var(--blue-mid);
}

/* CERT PREVIEW */
.cert-preview-text {
  font-size: 15px;
  color: var(--azure);
  margin-bottom: 24px;
  font-style: italic;
  font-family: 'Cormorant Garamond', serif;
}

.cert-pills {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.cert-pill {
  font-size: 12px;
  font-weight: 500;
  padding: 7px 16px;
  border-radius: 20px;
  border: 0.5px solid rgba(123,167,232,0.3);
  color: var(--azure);
  background: rgba(43,79,216,0.1);
}

/* GALLERY PREVIEW */
.gallery-preview { padding-top: clamp(48px, 6vw, 80px); padding-bottom: clamp(48px, 6vw, 80px); }

.gallery-sub {
  font-size: 15px;
  color: var(--blue-mid);
  margin-bottom: 28px;
  font-style: italic;
  font-family: 'Cormorant Garamond', serif;
}

.gallery-grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr;
  grid-template-rows: 200px 200px;
  gap: 10px;
}

.gallery-cell {
  border-radius: var(--r-md);
  overflow: hidden;
  background: var(--blue-light);
}

.gallery-cell-large { grid-row: span 2; }

.gallery-cell img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.4s ease;
}

.gallery-cell:hover img { transform: scale(1.04); }

/* CONTACT PREVIEW */
.contact-preview { text-align: center; }
.contact-preview .eyebrow { display: block; margin-bottom: 8px; }
.contact-preview h2 { margin-bottom: 16px; }

.contact-sub {
  font-size: 15px;
  color: var(--azure);
  max-width: 480px;
  margin: 0 auto 32px;
  line-height: 1.75;
}

/* RESPONSIVE */
@media (max-width: 1024px) {
  .hero-content { grid-template-columns: 1fr; }
  .hero-right { display: none; }
  .svc-grid { grid-template-columns: repeat(2, 1fr); }
  .about-grid { grid-template-columns: 1fr; }
}

@media (max-width: 640px) {
  .svc-grid { grid-template-columns: 1fr; }
  .hero-stats { flex-direction: column; align-items: flex-start; gap: 16px; }
  .stat-divider { display: none; }
  .gallery-grid { grid-template-columns: 1fr 1fr; grid-template-rows: auto; }
  .gallery-cell-large { grid-row: span 1; }
  .hero-ctas { flex-direction: column; }
  .hero-ctas .btn { width: 100%; justify-content: center; }
}
</style>

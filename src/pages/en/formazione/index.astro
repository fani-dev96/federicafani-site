---
import Layout from '../../../layouts/Layout.astro';
---

<Layout
  lang="en"
  title="Education — Federica Fanì"
  description="Certifications, courses and training. What I know how to do, I have a piece of paper to prove it. Most of the time."
>

  <!-- HERO -->
  <section class="form-hero">
    <div class="form-hero-inner">
      <div class="hero-eyebrow reveal">
        <span class="eyebrow-line"></span>
        <span class="eyebrow">Education</span>
      </div>
      <h1 class="reveal reveal-delay-1">Certifications</h1>
      <p class="form-hero-sub reveal reveal-delay-2">
        What I know how to do, I have a piece of paper to prove it. Most of the time.
      </p>
    </div>
  </section>

  <!-- ACCORDION -->
  <section class="section form-section">
    <div class="accordion-wrap">

      <div class="acc-gruppo reveal" style="--gruppo-color: #2B4FD8">
        <button class="acc-header" aria-expanded="false">
          <div class="acc-header-left">
            <div class="acc-platform">Luca La Mesa</div>
            <div class="acc-category">Social Media Training</div>
          </div>
          <div class="acc-header-right">
            <span class="acc-count">3 certifications</span>
            <svg class="acc-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
          </div>
        </button>
        <div class="acc-body">
          <div class="acc-items">
            <div class="cert-item">
              <div class="cert-info">
                <div class="cert-title">Social Media Training — Season 1</div>
                <div class="cert-meta">
                  <span class="cert-date">4 December 2020</span>
                  <span class="cert-num">N. 52921025</span>
                </div>
                <div class="cert-desc">Fundamentals of social media marketing: strategy, content, profile management and performance analysis.</div>
              </div>
              <div class="cert-img-wrap">
                <img src="/images/certs/cert1.jpg" alt="Certificate Social Media Training Season 1" loading="lazy" />
                <div class="cert-img-overlay">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
                  View
                </div>
              </div>
            </div>
            <div class="cert-item">
              <div class="cert-info">
                <div class="cert-title">Social Media Training — Season 2</div>
                <div class="cert-meta">
                  <span class="cert-date">6 April 2021</span>
                  <span class="cert-num">N. 61086703</span>
                </div>
                <div class="cert-desc">Advanced advertising, community management and performance metrics.</div>
              </div>
              <div class="cert-img-wrap">
                <img src="/images/certs/cert2.jpg" alt="Certificate Social Media Training Season 2" loading="lazy" />
                <div class="cert-img-overlay">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
                  View
                </div>
              </div>
            </div>
            <div class="cert-item">
              <div class="cert-info">
                <div class="cert-title">Social Media Training — Season 3</div>
                <div class="cert-meta">
                  <span class="cert-date">7 December 2021</span>
                  <span class="cert-num">N. 72176102</span>
                </div>
                <div class="cert-desc">Advanced content marketing strategies, personal branding and organic growth.</div>
              </div>
              <div class="cert-img-wrap">
                <img src="/images/certs/cert3.jpg" alt="Certificate Social Media Training Season 3" loading="lazy" />
                <div class="cert-img-overlay">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
                  View
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="acc-gruppo reveal" style="--gruppo-color: #8B1A1A">
        <button class="acc-header" aria-expanded="false">
          <div class="acc-header-left">
            <div class="acc-platform">Sapienza University of Rome</div>
            <div class="acc-category">University training</div>
          </div>
          <div class="acc-header-right">
            <span class="acc-count">1 certification</span>
            <svg class="acc-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
          </div>
        </button>
        <div class="acc-body">
          <div class="acc-items">
            <div class="cert-item">
              <div class="cert-info">
                <div class="cert-title">Cultures against gender-based violence: a transdisciplinary approach</div>
                <div class="cert-meta">
                  <span class="cert-date">8 March 2023</span>
                  <span class="cert-num">5 CFU · Department of Communication and Social Research</span>
                </div>
                <div class="cert-desc">Interdisciplinary training course on communication, gender and culture. Academic year 2022/2023.</div>
              </div>
              <div class="cert-img-wrap">
                <img src="/images/certs/cert4.jpg" alt="Sapienza certificate" loading="lazy" />
                <div class="cert-img-overlay">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
                  View
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="acc-gruppo reveal" style="--gruppo-color: #E8C97A">
        <button class="acc-header" aria-expanded="false">
          <div class="acc-header-left">
            <div class="acc-platform">In progress</div>
            <div class="acc-category">Ongoing certifications</div>
          </div>
          <div class="acc-header-right">
            <span class="acc-count">4 certifications</span>
            <svg class="acc-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
          </div>
        </button>
        <div class="acc-body">
          <div class="acc-items">
            <div class="cert-item">
              <div class="cert-info">
                <div class="cert-title">Google Analytics 4</div>
                <div class="cert-meta">
                  <span class="cert-date">In progress</span>
                  <span class="cert-num">Google Skillshop</span>
                </div>
                <div class="cert-desc">Official Google certification on GA4: data collection, analysis, reporting and optimisation.</div>
              </div>
              <div class="cert-soon-badge">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                In progress
              </div>
            </div>
            <div class="cert-item">
              <div class="cert-info">
                <div class="cert-title">Meta Blueprint — Facebook & Instagram Ads</div>
                <div class="cert-meta">
                  <span class="cert-date">In progress</span>
                  <span class="cert-num">Meta Blueprint</span>
                </div>
                <div class="cert-desc">Official Meta certification on advertising, targeting and campaign optimisation.</div>
              </div>
              <div class="cert-soon-badge">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                In progress
              </div>
            </div>
            <div class="cert-item">
              <div class="cert-info">
                <div class="cert-title">HubSpot Social Media Marketing</div>
                <div class="cert-meta">
                  <span class="cert-date">In progress</span>
                  <span class="cert-num">HubSpot Academy</span>
                </div>
                <div class="cert-desc">Social strategy, content marketing, community management and analytics.</div>
              </div>
              <div class="cert-soon-badge">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                In progress
              </div>
            </div>
            <div class="cert-item">
              <div class="cert-info">
                <div class="cert-title">CIPP/E — Certified Information Privacy Professional Europe</div>
                <div class="cert-meta">
                  <span class="cert-date">In progress</span>
                  <span class="cert-num">IAPP</span>
                </div>
                <div class="cert-desc">European standard for privacy and GDPR. Recognised across the EU.</div>
              </div>
              <div class="cert-soon-badge">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                In progress
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- LIGHTBOX -->
  <div class="lightbox" id="lightbox">
    <button class="lightbox-close" id="lightbox-close">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <button class="lightbox-prev" id="lightbox-prev">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
    </button>
    <img id="lightboxImg" src="" alt="" />
    <button class="lightbox-next" id="lightbox-next">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
    </button>
    <div class="lightbox-caption" id="lightbox-caption"></div>
  </div>

  <!-- NOTE -->
  <div class="section-dark">
    <section class="section note-section">
      <div class="note-grid">
        <div class="note-item reveal">
          <div class="note-ico">🎓</div>
          <div class="note-title">Degrees in progress</div>
          <div class="note-desc">Linguistic Mediation (University of Macerata, 2 exams left) and Communication Studies at Sapienza. Degrees will be added upon completion.</div>
        </div>
        <div class="note-item reveal reveal-delay-1">
          <div class="note-ico">📋</div>
          <div class="note-title">Upcoming certifications</div>
          <div class="note-desc">GA4, Meta Blueprint, HubSpot and CIPP/E are in progress. They will be added as soon as completed.</div>
        </div>
        <div class="note-item reveal reveal-delay-2">
          <div class="note-ico">🔒</div>
          <div class="note-title">Watermarked certificates</div>
          <div class="note-desc">Certificate images are watermark-protected. If you need to verify authenticity, write to me directly.</div>
        </div>
      </div>
    </section>
  </div>

</Layout>

<style>
.form-hero {
  padding: clamp(48px, 6vw, 80px) clamp(20px, 5vw, 80px) clamp(32px, 4vw, 56px);
  background: var(--blue-pale);
}

.form-hero-inner { max-width: 1200px; margin: 0 auto; }

.hero-eyebrow {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 16px;
}

.eyebrow-line {
  width: 32px;
  height: 1px;
  background: var(--blue);
  flex-shrink: 0;
}

.form-hero h1 {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(40px, 6vw, 72px);
  font-weight: 300;
  color: var(--blue-dark);
  line-height: 1.1;
  margin-bottom: 16px;
}

.form-hero-sub {
  font-size: 16px;
  color: var(--blue-mid);
  font-style: italic;
  font-family: 'Cormorant Garamond', serif;
}

.form-section {
  padding-top: clamp(48px, 6vw, 80px);
  padding-bottom: clamp(48px, 6vw, 80px);
}

.accordion-wrap {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.acc-gruppo {
  border: 0.5px solid rgba(43,79,216,0.15);
  border-radius: var(--r-lg);
  overflow: hidden;
  background: var(--white);
}

.acc-header {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22px 28px;
  background: none;
  border: none;
  cursor: pointer;
  text-align: left;
  gap: 16px;
  transition: background 0.2s ease;
  border-left: 4px solid var(--gruppo-color, var(--blue));
}

.acc-header:hover { background: var(--blue-pale); }
.acc-gruppo.open .acc-header { background: var(--blue-pale); }

.acc-header-left { display: flex; flex-direction: column; gap: 3px; }

.acc-platform {
  font-size: 16px;
  font-weight: 500;
  color: var(--blue-dark);
  font-family: 'Cormorant Garamond', serif;
}

.acc-category {
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--blue-mid);
}

.acc-header-right {
  display: flex;
  align-items: center;
  gap: 12px;
  flex-shrink: 0;
}

.acc-count {
  font-size: 12px;
  color: var(--blue-mid);
  white-space: nowrap;
}

.acc-chevron {
  color: var(--blue-mid);
  transition: transform 0.3s ease;
  flex-shrink: 0;
}

.acc-gruppo.open .acc-chevron { transform: rotate(180deg); }

.acc-body {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

.acc-gruppo.open .acc-body { max-height: 2000px; }

.acc-items {
  display: flex;
  flex-direction: column;
  border-top: 0.5px solid rgba(43,79,216,0.1);
}

.cert-item {
  display: grid;
  grid-template-columns: 1fr 280px;
  gap: 24px;
  align-items: center;
  padding: 24px 28px;
  border-bottom: 0.5px solid rgba(43,79,216,0.08);
  transition: background 0.2s ease;
}

.cert-item:last-child { border-bottom: none; }
.cert-item:hover { background: rgba(43,79,216,0.02); }

.cert-title {
  font-size: 15px;
  font-weight: 500;
  color: var(--blue-dark);
  margin-bottom: 6px;
}

.cert-meta {
  display: flex;
  gap: 12px;
  align-items: center;
  margin-bottom: 8px;
  flex-wrap: wrap;
}

.cert-date {
  font-size: 12px;
  color: var(--blue);
  font-weight: 500;
}

.cert-num {
  font-size: 11px;
  color: var(--blue-mid);
  background: var(--blue-light);
  padding: 2px 8px;
  border-radius: 20px;
}

.cert-desc {
  font-size: 13px;
  color: var(--blue-mid);
  line-height: 1.7;
}

.cert-img-wrap {
  position: relative;
  border-radius: var(--r-md);
  overflow: hidden;
  cursor: pointer;
  border: 0.5px solid rgba(43,79,216,0.15);
}

.cert-img-wrap img {
  width: 100%;
  height: 160px;
  object-fit: cover;
  display: block;
  transition: transform 0.3s ease;
}

.cert-img-wrap:hover img { transform: scale(1.03); }

.cert-img-overlay {
  position: absolute;
  inset: 0;
  background: rgba(10,22,40,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  color: var(--white);
  font-size: 13px;
  font-weight: 500;
  opacity: 0;
  transition: opacity 0.2s ease;
}

.cert-img-wrap:hover .cert-img-overlay { opacity: 1; }

.cert-soon-badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 12px;
  font-weight: 500;
  color: var(--gold);
  background: rgba(232,201,122,0.15);
  border: 0.5px solid rgba(232,201,122,0.3);
  padding: 8px 14px;
  border-radius: 20px;
  justify-self: center;
}

.lightbox {
  position: fixed;
  inset: 0;
  background: rgba(10,22,40,0.92);
  z-index: 1000;
  display: none;
  align-items: center;
  justify-content: center;
  padding: 40px;
}

.lightbox.open { display: flex; }

.lightbox img {
  max-width: 80vw;
  max-height: 85vh;
  object-fit: contain;
  border-radius: var(--r-md);
  box-shadow: 0 24px 80px rgba(0,0,0,0.5);
  cursor: default;
}

.lightbox-close {
  position: absolute;
  top: 20px;
  right: 20px;
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: rgba(255,255,255,0.1);
  border: 0.5px solid rgba(255,255,255,0.2);
  color: var(--white);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: background 0.2s ease;
  z-index: 10;
}

.lightbox-close:hover { background: rgba(255,255,255,0.2); }

.lightbox-prev,
.lightbox-next {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: rgba(255,255,255,0.1);
  border: 0.5px solid rgba(255,255,255,0.2);
  color: var(--white);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: background 0.2s ease;
  z-index: 10;
}

.lightbox-prev { left: 20px; }
.lightbox-next { right: 20px; }
.lightbox-prev:hover,
.lightbox-next:hover { background: rgba(255,255,255,0.2); }

.lightbox-caption {
  position: absolute;
  bottom: 20px;
  left: 50%;
  transform: translateX(-50%);
  font-size: 12px;
  color: rgba(255,255,255,0.5);
  white-space: nowrap;
}

.note-section { padding-top: clamp(48px, 6vw, 80px); padding-bottom: clamp(48px, 6vw, 80px); }

.note-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
}

.note-item {
  background: rgba(43,79,216,0.1);
  border: 0.5px solid rgba(123,167,232,0.2);
  border-radius: var(--r-lg);
  padding: 24px;
}

.note-ico { font-size: 28px; margin-bottom: 12px; }
.note-title { font-size: 15px; font-weight: 500; color: var(--white); margin-bottom: 8px; font-family: 'Cormorant Garamond', serif; }
.note-desc { font-size: 13px; color: var(--azure); line-height: 1.75; }

@media (max-width: 900px) {
  .cert-item { grid-template-columns: 1fr; }
  .cert-img-wrap img { height: 200px; }
  .note-grid { grid-template-columns: 1fr; }
}

@media (max-width: 640px) {
  .acc-header { padding: 16px 20px; }
  .cert-item { padding: 20px; }
}
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.acc-header').forEach(btn => {
      btn.addEventListener('click', () => {
        const gruppo = btn.closest('.acc-gruppo');
        const isOpen = gruppo.classList.contains('open');
        document.querySelectorAll('.acc-gruppo.open').forEach(g => g.classList.remove('open'));
        if (!isOpen) {
          gruppo.classList.add('open');
          btn.setAttribute('aria-expanded', 'true');
        } else {
          btn.setAttribute('aria-expanded', 'false');
        }
      });
    });

    const lb = document.getElementById('lightbox');
    const lbImg = document.getElementById('lightboxImg');
    const lbCaption = document.getElementById('lightbox-caption');
    let certImages = [];
    let currentCertIndex = 0;

    function openCertLightbox(idx) {
      if (idx < 0 || idx >= certImages.length) return;
      currentCertIndex = idx;
      const img = certImages[idx];
      if (!lbImg) return;
      lbImg.src = img.src;
      lbImg.alt = img.alt;
      if (lbCaption) lbCaption.textContent = `${idx + 1} / ${certImages.length}`;
      lb?.classList.add('open');
      document.body.style.overflow = 'hidden';
    }

    function closeLightbox() {
      lb?.classList.remove('open');
      document.body.style.overflow = '';
    }

    document.addEventListener('click', e => {
      const imgWrap = e.target.closest('.cert-img-wrap');
      if (imgWrap) {
        certImages = Array.from(document.querySelectorAll('.cert-img-wrap img'));
        const img = imgWrap.querySelector('img');
        const idx = certImages.indexOf(img);
        openCertLightbox(idx >= 0 ? idx : 0);
      }
    });

    document.getElementById('lightbox-prev')?.addEventListener('click', e => {
      e.stopPropagation();
      openCertLightbox(currentCertIndex - 1);
    });

    document.getElementById('lightbox-next')?.addEventListener('click', e => {
      e.stopPropagation();
      openCertLightbox(currentCertIndex + 1);
    });

    document.getElementById('lightbox-close')?.addEventListener('click', closeLightbox);

    lb?.addEventListener('click', e => {
      if (e.target === lb) closeLightbox();
    });

    document.addEventListener('keydown', e => {
      if (!lb?.classList.contains('open')) return;
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowLeft') openCertLightbox(currentCertIndex - 1);
      if (e.key === 'ArrowRight') openCertLightbox(currentCertIndex + 1);
    });
  });
</script>
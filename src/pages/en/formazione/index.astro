---
import Layout from '../../../layouts/Layout.astro';
---
<Layout title="Education — Federica Fanì" description="What I know how to do, I have a piece of paper to prove it. Most of the time." lang="en">
  <section class="gall-hero">
    <div class="gall-hero-inner">
      <div class="hero-eyebrow reveal"><span class="eyebrow-line"></span><span class="eyebrow">Education</span></div>
      <h1 class="reveal reveal-delay-1">Certifications</h1>
      <p class="gall-hero-sub reveal reveal-delay-2">What I know how to do, I have a piece of paper to prove it. Most of the time.</p>
    </div>
  </section>

  <section class="section form-section">
    <div class="accordion-wrap">
      <div class="acc-gruppo reveal" style="--gruppo-color: #2B4FD8">
        <button class="acc-header" aria-expanded="false">
          <div class="acc-header-left"><div class="acc-platform">Luca La Mesa</div><div class="acc-category">Social Media Training</div></div>
          <div class="acc-header-right"><span class="acc-count">3 certifications</span><svg class="acc-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg></div>
        </button>
        <div class="acc-body">
          <div class="acc-items">
            <div class="cert-item"><div class="cert-info"><div class="cert-title">Social Media Training — Season 1</div><div class="cert-meta"><span class="cert-date">4 December 2020</span><span class="cert-num">N. 52921025</span></div><div class="cert-desc">Fundamentals of social media marketing: strategy, content, profile management and performance analysis.</div></div><div class="cert-img-wrap"><img src="/images/certs/cert1.jpg" alt="Certificate Social Media Training Season 1" loading="lazy" /><div class="cert-img-overlay"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg> View</div></div></div>
            <div class="cert-item"><div class="cert-info"><div class="cert-title">Social Media Training — Season 2</div><div class="cert-meta"><span class="cert-date">6 April 2021</span><span class="cert-num">N. 61086703</span></div><div class="cert-desc">Advanced advertising, community management and performance metrics.</div></div><div class="cert-img-wrap"><img src="/images/certs/cert2.jpg" alt="Certificate Social Media Training Season 2" loading="lazy" /><div class="cert-img-overlay"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg> View</div></div></div>
            <div class="cert-item"><div class="cert-info"><div class="cert-title">Social Media Training — Season 3</div><div class="cert-meta"><span class="cert-date">7 December 2021</span><span class="cert-num">N. 72176102</span></div><div class="cert-desc">Advanced content marketing strategies, personal branding and organic growth.</div></div><div class="cert-img-wrap"><img src="/images/certs/cert3.jpg" alt="Certificate Social Media Training Season 3" loading="lazy" /><div class="cert-img-overlay"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg> View</div></div></div>
          </div>
        </div>
      </div>

      <div class="acc-gruppo reveal" style="--gruppo-color: #8B1A1A">
        <button class="acc-header" aria-expanded="false">
          <div class="acc-header-left"><div class="acc-platform">Sapienza University of Rome</div><div class="acc-category">University training</div></div>
          <div class="acc-header-right"><span class="acc-count">1 certification</span><svg class="acc-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg></div>
        </button>
        <div class="acc-body">
          <div class="acc-items">
            <div class="cert-item"><div class="cert-info"><div class="cert-title">Cultures against gender-based violence: a transdisciplinary approach</div><div class="cert-meta"><span class="cert-date">8 March 2023</span><span class="cert-num">5 CFU · Department of Communication and Social Research</span></div><div class="cert-desc">Interdisciplinary training course on communication, gender and culture. Academic year 2022/2023.</div></div><div class="cert-img-wrap"><img src="/images/certs/cert4.jpg" alt="Sapienza certificate" loading="lazy" /><div class="cert-img-overlay"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg> View</div></div></div>
          </div>
        </div>
      </div>

      <div class="acc-gruppo reveal" style="--gruppo-color: #E8C97A">
        <button class="acc-header" aria-expanded="false">
          <div class="acc-header-left"><div class="acc-platform">In progress</div><div class="acc-category">Ongoing certifications</div></div>
          <div class="acc-header-right"><span class="acc-count">4 certifications</span><svg class="acc-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg></div>
        </button>
        <div class="acc-body">
          <div class="acc-items">
            <div class="cert-item"><div class="cert-info"><div class="cert-title">Google Analytics 4</div><div class="cert-meta"><span class="cert-date">In progress</span><span class="cert-num">Google Skillshop</span></div><div class="cert-desc">Official Google certification on GA4: data collection, analysis, reporting and optimisation.</div></div><div class="cert-soon-badge"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg> In progress</div></div>
            <div class="cert-item"><div class="cert-info"><div class="cert-title">Meta Blueprint — Facebook & Instagram Ads</div><div class="cert-meta"><span class="cert-date">In progress</span><span class="cert-num">Meta Blueprint</span></div><div class="cert-desc">Official Meta certification on advertising, targeting and campaign optimisation.</div></div><div class="cert-soon-badge"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg> In progress</div></div>
            <div class="cert-item"><div class="cert-info"><div class="cert-title">HubSpot Social Media Marketing</div><div class="cert-meta"><span class="cert-date">In progress</span><span class="cert-num">HubSpot Academy</span></div><div class="cert-desc">Social strategy, content marketing, community management and analytics.</div></div><div class="cert-soon-badge"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg> In progress</div></div>
            <div class="cert-item"><div class="cert-info"><div class="cert-title">CIPP/E — Certified Information Privacy Professional Europe</div><div class="cert-meta"><span class="cert-date">In progress</span><span class="cert-num">IAPP</span></div><div class="cert-desc">European standard for privacy and GDPR. Recognised across the EU.</div></div><div class="cert-soon-badge"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg> In progress</div></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="lightbox" id="lightbox">
    <button class="lightbox-close" id="lightbox-close"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
    <button class="lightbox-prev" id="lightbox-prev"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg></button>
    <img id="lightboxImg" src="" alt="" />
    <button class="lightbox-next" id="lightbox-next"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></button>
    <div class="lightbox-caption" id="lightbox-caption"></div>
  </div>

  <div class="section-dark">
    <section class="section note-section">
      <div class="note-grid">
        <div class="note-item reveal"><div class="note-ico">🎓</div><div class="note-title">Degrees in progress</div><div class="note-desc">Modern Languages (University of Macerata, 2 exams remaining) and Communication Studies at Sapienza. Degrees will be added upon completion.</div></div>
        <div class="note-item reveal reveal-delay-1"><div class="note-ico">📋</div><div class="note-title">Upcoming certifications</div><div class="note-desc">GA4, Meta Blueprint, HubSpot and CIPP/E are in progress. They will be added as soon as they are completed.</div></div>
        <div class="note-item reveal reveal-delay-2"><div class="note-ico">🔒</div><div class="note-title">Watermarked certificates</div><div class="note-desc">Certificate images are protected by watermark. If you need to verify authenticity, feel free to get in touch directly.</div></div>
      </div>
    </section>
  </div>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.acc-header').forEach(btn => {
      btn.addEventListener('click', () => {
        const gruppo = btn.closest('.acc-gruppo');
        const isOpen = gruppo.classList.contains('open');
        document.querySelectorAll('.acc-gruppo.open').forEach(g => g.classList.remove('open'));
        if (!isOpen) { gruppo.classList.add('open'); btn.setAttribute('aria-expanded', 'true'); }
        else { btn.setAttribute('aria-expanded', 'false'); }
      });
    });
    const lb = document.getElementById('lightbox');
    const lbImg = document.getElementById('lightboxImg');
    const lbCaption = document.getElementById('lightbox-caption');
    let certImages = []; let currentCertIndex = 0;
    function openCertLightbox(idx) {
      if (idx < 0 || idx >= certImages.length) return;
      currentCertIndex = idx;
      const img = certImages[idx];
      if (!lbImg) return;
      lbImg.src = img.src; lbImg.alt = img.alt;
      if (lbCaption) lbCaption.textContent = `${idx + 1} / ${certImages.length}`;
      lb?.classList.add('open'); document.body.style.overflow = 'hidden';
    }
    function closeLightbox() { lb?.classList.remove('open'); document.body.style.overflow = ''; }
    document.addEventListener('click', e => {
      const imgWrap = e.target.closest('.cert-img-wrap');
      if (imgWrap) { certImages = Array.from(document.querySelectorAll('.cert-img-wrap img')); const img = imgWrap.querySelector('img'); const idx = certImages.indexOf(img); openCertLightbox(idx >= 0 ? idx : 0); }
    });
    document.getElementById('lightbox-prev')?.addEventListener('click', e => { e.stopPropagation(); openCertLightbox(currentCertIndex - 1); });
    document.getElementById('lightbox-next')?.addEventListener('click', e => { e.stopPropagation(); openCertLightbox(currentCertIndex + 1); });
    document.getElementById('lightbox-close')?.addEventListener('click', closeLightbox);
    lb?.addEventListener('click', e => { if (e.target === lb) closeLightbox(); });
    document.addEventListener('keydown', e => { if (!lb?.classList.contains('open')) return; if (e.key === 'Escape') closeLightbox(); if (e.key === 'ArrowLeft') openCertLightbox(currentCertIndex - 1); if (e.key === 'ArrowRight') openCertLightbox(currentCertIndex + 1); });
  });
</script>

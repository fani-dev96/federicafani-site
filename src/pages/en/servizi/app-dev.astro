---
import Layout from '../../../layouts/Layout.astro';
---

<Layout
  lang="en"
  title="App & SaaS Development — Federica Fanì"
  description="Native Android app development in Flutter, web apps and small SaaS. From concept to deploy, with a crafted approach."
>

  <!-- HERO -->
  <section class="app-hero">
    <div class="app-hero-inner">
      <div class="breadcrumb reveal">
        <a href="/en/servizi">Services</a>
        <span>→</span>
        <span>App & SaaS Development</span>
      </div>
      <h1 class="reveal reveal-delay-1">App & SaaS<br><em>Development</em></h1>
      <p class="app-hero-sub reveal reveal-delay-2">
        From concept to deploy. No off-the-shelf solutions — every project built from scratch.
      </p>
    </div>
  </section>

  <!-- APPROCCIO -->
  <section class="section approach-section">
    <div class="approach-grid">
      <div class="approach-text">
        <span class="eyebrow reveal">My approach</span>
        <h2 class="reveal reveal-delay-1">Crafted, not mass-produced</h2>
        <p class="reveal reveal-delay-2">I develop native Android apps in Flutter and web apps, from concept to deploy. I work on my own projects and take on freelance collaborations with a crafted approach: no off-the-shelf solutions, every project is thought through from scratch based on real needs.</p>
        <p class="reveal reveal-delay-2" style="margin-top: 12px;">I'm open to projects proportionate to individual work: Android apps, web apps, small SaaS. If you have an idea and want to know whether it's feasible, write to me.</p>

        <div class="tech-stack reveal reveal-delay-3">
          <div class="tech-label">Tech stack</div>
          <div class="tech-pills">
            <span class="tech-pill">Flutter</span>
            <span class="tech-pill">Dart</span>
            <span class="tech-pill">Firebase</span>
            <span class="tech-pill">Android</span>
            <span class="tech-pill">Astro</span>
            <span class="tech-pill">HTML/CSS/JS</span>
            <span class="tech-pill">GitHub</span>
            <span class="tech-pill">Vercel</span>
          </div>
        </div>
      </div>

      <div class="approach-side reveal reveal-delay-2">
        <div class="approach-stat">
          <div class="stat-big">Flutter</div>
          <div class="stat-label">Main framework · used by Google Pay, BMW, Nubank</div>
        </div>
        <div class="approach-stat">
          <div class="stat-big">Android</div>
          <div class="stat-label">Primary target · iOS on request</div>
        </div>
        <div class="approach-stat">
          <div class="stat-big">1 person</div>
          <div class="stat-label">No middlemen, direct contact</div>
        </div>
      </div>
    </div>
  </section>

  <!-- PROGETTI -->
  <div class="section-dark">
    <section class="section projects-section">
      <div class="sec-header">
        <div class="sec-header-left">
          <span class="eyebrow eyebrow-light reveal">Portfolio</span>
          <h2 class="sec-title-light reveal reveal-delay-1">Projects</h2>
        </div>
        <a href="/en/portfolio" class="sec-link sec-link-light reveal">See all →</a>
      </div>

      <div class="projects-grid">
        <div class="project-card reveal">
          <div class="project-header">
            <div class="project-ico">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <div class="project-tag">Android · Flutter</div>
          </div>
          <div class="project-name">Magnebevo Client App</div>
          <div class="project-desc">Android app for customers of Magnebevo (Pigneto, Rome). Menu, events, promotions and real-time updates.</div>
          <div class="project-client">Client: Magnebevo · Via del Pigneto 93, Rome</div>
        </div>

        <div class="project-card reveal reveal-delay-1">
          <div class="project-header">
            <div class="project-ico">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
            </div>
            <div class="project-tag">Android · Flutter</div>
          </div>
          <div class="project-name">Magnebevo Staff App</div>
          <div class="project-desc">Android app for internal staff management. An operational tool to simplify day-to-day team communication and organisation.</div>
          <div class="project-client">Client: Magnebevo · Internal use</div>
        </div>

        <div class="project-card project-card-soon reveal reveal-delay-2">
          <div class="project-header">
            <div class="project-ico">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            </div>
            <div class="project-tag">In development</div>
          </div>
          <div class="project-name">More projects</div>
          <div class="project-desc">SaaS projects in development. Details will be available at launch.</div>
          <div class="project-soon">Coming soon</div>
        </div>
      </div>
    </section>
  </div>

  <!-- PREZZI -->
  <section class="section pricing-section">
    <div class="sec-header">
      <div class="sec-header-left">
        <span class="eyebrow reveal">Investment</span>
        <h2 class="reveal reveal-delay-1">Development rates</h2>
      </div>
    </div>
    <p class="pricing-sub reveal reveal-delay-2">Every project is different — these are reference points. The final quote depends on complexity and required features.</p>

    <div class="dev-pricing-grid">
      <div class="dev-pricing-card reveal">
        <div class="dev-pricing-header">
          <div class="dev-p-label">Consulting</div>
          <div class="dev-p-price">€50<span>/hour</span></div>
        </div>
        <div class="dev-p-desc">Project analysis, requirements definition, existing code review, technical support.</div>
        <ul class="dev-features">
          <li>Technical feasibility analysis</li>
          <li>Architecture definition</li>
          <li>Code review and optimisation</li>
          <li>Post-launch support</li>
        </ul>
      </div>

      <div class="dev-pricing-card reveal reveal-delay-1">
        <div class="dev-pricing-header">
          <div class="dev-p-label">MVP App</div>
          <div class="dev-p-price">from €3.000</div>
        </div>
        <div class="dev-p-desc">Functional Android app with core features. Ideal for validating an idea before investing further.</div>
        <ul class="dev-features">
          <li>Android app in Flutter</li>
          <li>3–5 main screens</li>
          <li>Basic Firebase backend</li>
          <li>Play Store deployment</li>
          <li>1 month post-launch support</li>
        </ul>
      </div>

      <div class="dev-pricing-card reveal reveal-delay-2">
        <div class="dev-pricing-header">
          <div class="dev-p-label">Full app</div>
          <div class="dev-p-price">quote</div>
        </div>
        <div class="dev-p-desc">App with advanced features, user authentication, database, push notifications and admin panel.</div>
        <ul class="dev-features">
          <li>Full Android app in Flutter</li>
          <li>Authentication and user profiles</li>
          <li>Firebase database and backend</li>
          <li>Push notifications</li>
          <li>Web admin panel</li>
          <li>3 months post-launch support</li>
        </ul>
        <div class="dev-p-note">Custom quote on request</div>
      </div>

      <div class="dev-pricing-card reveal reveal-delay-3">
        <div class="dev-pricing-header">
          <div class="dev-p-label">Website / Web app</div>
          <div class="dev-p-price">from €800</div>
        </div>
        <div class="dev-p-desc">Static sites, landing pages, portfolios or simple web apps. Stack: Astro, HTML/CSS/JS, Vercel.</div>
        <ul class="dev-features">
          <li>Custom design</li>
          <li>Mobile responsive</li>
          <li>SEO optimised</li>
          <li>Deployment and domain setup</li>
          <li>Optional CMS</li>
        </ul>
      </div>
    </div>

    <div class="pricing-disclaimer reveal">
      All prices are VAT excluded and indicative. The final quote is defined after a project analysis. Delivery times vary depending on complexity.
    </div>
  </section>

  <!-- CTA -->
  <div class="section-dark">
    <section class="section cta-section">
      <div class="cta-inner">
        <span class="eyebrow eyebrow-light reveal">Let's talk</span>
        <h2 class="sec-title-light reveal reveal-delay-1">Got an idea?</h2>
        <p class="cta-sub reveal reveal-delay-2">Write to me to figure out together whether your project is feasible, how much it costs and how long it takes. The first analysis is free.</p>
        <div class="cta-btns reveal reveal-delay-3">
          <a href="/en/contatti" class="btn btn-gold">Write to me</a>
          <a href="/en/portfolio" class="btn btn-outline-light">See the portfolio</a>
        </div>
      </div>
    </section>
  </div>

</Layout>

<style>
.app-hero {
  padding: clamp(48px, 6vw, 80px) clamp(20px, 5vw, 80px) clamp(32px, 4vw, 56px);
  background: var(--blue-pale);
}

.app-hero-inner { max-width: 1200px; margin: 0 auto; }

.breadcrumb {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 12px;
  color: var(--blue-mid);
  margin-bottom: 20px;
}

.breadcrumb a { color: var(--blue); transition: opacity 0.2s; }
.breadcrumb a:hover { opacity: 0.7; }

.app-hero h1 {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(40px, 6vw, 72px);
  font-weight: 300;
  color: var(--blue-dark);
  line-height: 1.1;
  margin-bottom: 16px;
}

.app-hero h1 em { font-style: italic; color: var(--blue); }

.app-hero-sub {
  font-size: 16px;
  color: var(--blue-mid);
  font-style: italic;
  font-family: 'Cormorant Garamond', serif;
}

.approach-section { padding-top: clamp(48px, 6vw, 80px); padding-bottom: clamp(48px, 6vw, 80px); }

.approach-grid {
  display: grid;
  grid-template-columns: 1fr 280px;
  gap: clamp(40px, 6vw, 80px);
  align-items: start;
}

.approach-text h2 { color: var(--blue-dark); margin-bottom: 16px; }
.approach-text p { font-size: 15px; color: var(--blue-mid); line-height: 1.8; }

.tech-stack { margin-top: 28px; }

.tech-label {
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--blue);
  margin-bottom: 12px;
}

.tech-pills { display: flex; flex-wrap: wrap; gap: 8px; }

.tech-pill {
  font-size: 12px;
  font-weight: 500;
  padding: 5px 12px;
  border-radius: 20px;
  background: var(--blue-light);
  color: var(--blue);
  border: 0.5px solid rgba(43,79,216,0.2);
}

.approach-side { display: flex; flex-direction: column; gap: 16px; }

.approach-stat {
  padding: 18px 20px;
  background: var(--blue-light);
  border-radius: var(--r-md);
  border: 0.5px solid rgba(43,79,216,0.15);
}

.stat-big {
  font-family: 'Cormorant Garamond', serif;
  font-size: 24px;
  font-weight: 400;
  color: var(--blue);
  margin-bottom: 4px;
}

.stat-label { font-size: 11px; color: var(--blue-mid); line-height: 1.5; }

.projects-section { padding-top: clamp(48px, 6vw, 80px); padding-bottom: clamp(48px, 6vw, 80px); }

.projects-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
}

.project-card {
  background: rgba(43,79,216,0.1);
  border: 0.5px solid rgba(123,167,232,0.2);
  border-radius: var(--r-lg);
  padding: 24px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.project-card-soon { opacity: 0.6; }

.project-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.project-ico {
  width: 36px;
  height: 36px;
  border-radius: var(--r-sm);
  background: rgba(43,79,216,0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--azure);
}

.project-tag {
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 0.06em;
  background: rgba(43,79,216,0.2);
  color: var(--azure);
  padding: 3px 9px;
  border-radius: 20px;
}

.project-name {
  font-size: 16px;
  font-weight: 500;
  color: var(--white);
  font-family: 'Cormorant Garamond', serif;
}

.project-desc { font-size: 13px; color: var(--azure); line-height: 1.7; flex: 1; }

.project-client {
  font-size: 11px;
  color: rgba(123,167,232,0.5);
  font-style: italic;
}

.project-soon {
  font-size: 11px;
  color: var(--gold);
  font-weight: 500;
}

.pricing-section { padding-top: clamp(48px, 6vw, 80px); padding-bottom: clamp(48px, 6vw, 80px); }

.pricing-sub {
  font-size: 14px;
  color: var(--blue-mid);
  margin-bottom: 32px;
  font-style: italic;
  font-family: 'Cormorant Garamond', serif;
  max-width: 600px;
}

.dev-pricing-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14px;
  margin-bottom: 20px;
}

.dev-pricing-card {
  background: var(--white);
  border: 0.5px solid rgba(43,79,216,0.12);
  border-radius: var(--r-lg);
  padding: 24px;
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.dev-pricing-header { display: flex; flex-direction: column; gap: 6px; }

.dev-p-label {
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--blue);
}

.dev-p-price {
  font-family: 'Cormorant Garamond', serif;
  font-size: 32px;
  font-weight: 400;
  color: var(--blue-dark);
  line-height: 1;
}

.dev-p-price span { font-size: 16px; color: var(--blue-mid); }

.dev-p-desc { font-size: 13px; color: var(--blue-mid); line-height: 1.6; }

.dev-features {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 7px;
  flex: 1;
}

.dev-features li {
  font-size: 12px;
  color: var(--blue-mid);
  padding-left: 14px;
  position: relative;
  line-height: 1.5;
}

.dev-features li::before {
  content: '→';
  position: absolute;
  left: 0;
  color: var(--blue);
  font-size: 11px;
}

.dev-p-note {
  font-size: 11px;
  color: var(--blue);
  font-style: italic;
  margin-top: auto;
}

.pricing-disclaimer {
  font-size: 11px;
  color: var(--blue-mid);
  line-height: 1.6;
}

.cta-section { text-align: center; }
.cta-section .eyebrow { display: block; margin-bottom: 8px; }
.cta-section h2 { margin-bottom: 16px; }
.cta-sub { font-size: 15px; color: var(--azure); max-width: 480px; margin: 0 auto 32px; line-height: 1.75; }
.cta-btns { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }

@media (max-width: 1024px) {
  .dev-pricing-grid { grid-template-columns: 1fr 1fr; }
  .projects-grid { grid-template-columns: 1fr; max-width: 480px; }
}

@media (max-width: 768px) {
  .approach-grid { grid-template-columns: 1fr; }
  .dev-pricing-grid { grid-template-columns: 1fr; }
}
</style>
---
import Layout from '../../../layouts/Layout.astro';
---

<Layout
  lang="en"
  title="Social Media Management — Federica Fanì"
  description="Social media management, content creation, photography and analytics for brands and venues. Authenticity first."
>

  <!-- HERO -->
  <section class="smm-hero">
    <div class="smm-hero-inner">
      <div class="breadcrumb reveal">
        <a href="/en/servizi">Services</a>
        <span>→</span>
        <span>Social Media Management</span>
      </div>
      <h1 class="reveal reveal-delay-1">Social Media<br><em>Management</em></h1>
      <p class="smm-hero-sub reveal reveal-delay-2">
        Social media is full of content. What's almost always missing is personality.
      </p>
    </div>
  </section>

  <!-- APPROCCIO -->
  <section class="section approach-section">
    <div class="approach-grid">
      <div class="approach-text">
        <span class="eyebrow reveal">My approach</span>
        <h2 class="reveal reveal-delay-1">Authenticity first</h2>
        <p class="reveal reveal-delay-2">I always start with a simple question: what makes this place, this brand, this person unique? Then we build everything else around that answer: strategy, content, photos, video. Because a profile that converts is first of all a profile that feels real.</p>
        <div class="approach-list reveal reveal-delay-3">
          <div class="approach-item">
            <span class="approach-check">✓</span>
            <span>Full profile management (Instagram, Facebook, TikTok)</span>
          </div>
          <div class="approach-item">
            <span class="approach-check">✓</span>
            <span>Content creation: captions, graphics, Reels, Stories</span>
          </div>
          <div class="approach-item">
            <span class="approach-check">✓</span>
            <span>On-site photography and video (Pigneto area, Rome)</span>
          </div>
          <div class="approach-item">
            <span class="approach-check">✓</span>
            <span>Editorial planning and content calendar</span>
          </div>
          <div class="approach-item">
            <span class="approach-check">✓</span>
            <span>Monthly performance monitoring and analytics</span>
          </div>
        </div>
      </div>
      <div class="approach-side reveal reveal-delay-2">
        <div class="approach-stat">
          <div class="stat-big">3+</div>
          <div class="stat-label">Years of experience</div>
        </div>
        <div class="approach-stat">
          <div class="stat-big">IT · EN · ES · FR</div>
          <div class="stat-label">Multilingual content</div>
        </div>
        <div class="approach-stat">
          <div class="stat-big">Rome</div>
          <div class="stat-label">On-site photography (Pigneto area)</div>
        </div>
      </div>
    </div>
  </section>

  <!-- PREZZI -->
  <div class="section-dark">
    <section class="section pricing-section">
      <div class="sec-header">
        <div class="sec-header-left">
          <span class="eyebrow eyebrow-light reveal">Investment</span>
          <h2 class="sec-title-light reveal reveal-delay-1">SMM Packages</h2>
        </div>
      </div>
      <p class="pricing-sub reveal reveal-delay-2">All packages include a monthly performance report. If none of these fits your needs, get in touch: we'll build a custom quote together.</p>

      <div class="pricing-grid">

        <div class="pricing-card reveal">
          <div class="pricing-label">Starter</div>
          <div class="pricing-price">
            <span class="p-val">€400</span>
            <span class="p-period">/month</span>
          </div>
          <div class="pricing-desc">Ideal for those just starting out or wanting to test professional social media management.</div>
          <ul class="pricing-features">
            <li>1 platform (Instagram or Facebook)</li>
            <li>8–10 posts per month</li>
            <li>Captions and graphics included</li>
            <li>Monthly editorial plan</li>
            <li>Basic performance report</li>
          </ul>
          <div class="pricing-note">On-site photography not included (separate package)</div>
          <a href="/en/contatti" class="btn btn-outline-light pricing-btn">Get in touch</a>
        </div>

        <div class="pricing-card pricing-card-featured reveal reveal-delay-1">
          <div class="pricing-label-featured">Most popular</div>
          <div class="pricing-label">Standard</div>
          <div class="pricing-price">
            <span class="p-val">€700</span>
            <span class="p-period">/month</span>
          </div>
          <div class="pricing-desc">Full management with on-site photography. The most requested package for venues and commercial businesses.</div>
          <ul class="pricing-features">
            <li>2 platforms (Instagram + Facebook)</li>
            <li>12–15 posts per month</li>
            <li>Stories and Reels included</li>
            <li>1 on-site photo session per month</li>
            <li>Monthly editorial plan</li>
            <li>Full performance report</li>
            <li>Comments and DM management</li>
          </ul>
          <a href="/en/contatti" class="btn btn-gold pricing-btn">Request a quote</a>
        </div>

        <div class="pricing-card reveal reveal-delay-2">
          <div class="pricing-label">Premium</div>
          <div class="pricing-price">
            <span class="p-val">€1.200</span>
            <span class="p-period">/month</span>
          </div>
          <div class="pricing-desc">Full multi-channel management with advanced analytics. For brands that want to grow in a structured way.</div>
          <ul class="pricing-features">
            <li>3 platforms (Instagram + Facebook + TikTok)</li>
            <li>20+ pieces of content per month</li>
            <li>Reels, Stories, TikTok videos</li>
            <li>2 on-site photo sessions per month</li>
            <li>Quarterly editorial strategy</li>
            <li>Advanced analytics with Looker Studio</li>
            <li>Full comments and DM management</li>
            <li>Monthly 1:1 consultation</li>
          </ul>
          <a href="/en/contatti" class="btn btn-outline-light pricing-btn">Get in touch</a>
        </div>

      </div>

      <div class="pricing-extra reveal">
        <div class="extra-title">Add-on services</div>
        <div class="extra-grid">
          <div class="extra-item">
            <span class="extra-name">Extra photo session</span>
            <span class="extra-price">from €150</span>
          </div>
          <div class="extra-item">
            <span class="extra-name">Profile setup from scratch</span>
            <span class="extra-price">€200 one-off</span>
          </div>
          <div class="extra-item">
            <span class="extra-name">Meta Ads management (paid)</span>
            <span class="extra-price">€150/month + ad budget</span>
          </div>
          <div class="extra-item">
            <span class="extra-name">Multilingual content (EN/ES)</span>
            <span class="extra-price">+€100/month</span>
          </div>
        </div>
      </div>

      <div class="pricing-disclaimer reveal">
        All prices are VAT excluded. Packages have a minimum duration of 3 months. Custom quotes available for specific needs.
      </div>
    </section>
  </div>

  <!-- PER CHI -->
  <section class="section forchi-section">
    <div class="sec-header">
      <div class="sec-header-left">
        <span class="eyebrow reveal">Who it's for</span>
        <h2 class="reveal reveal-delay-1">I work well with</h2>
      </div>
    </div>
    <div class="forchi-grid">
      <div class="forchi-item reveal">
        <div class="forchi-ico">🍸</div>
        <div class="forchi-title">Bars and venues</div>
        <div class="forchi-desc">From social management to event calendars, on-site photography included. Magnebevo has been my main client for over a year.</div>
      </div>
      <div class="forchi-item reveal reveal-delay-1">
        <div class="forchi-ico">🛍️</div>
        <div class="forchi-title">Shops and businesses</div>
        <div class="forchi-desc">Products, promotions, brand storytelling. Content that sells without looking like advertising.</div>
      </div>
      <div class="forchi-item reveal reveal-delay-2">
        <div class="forchi-ico">👤</div>
        <div class="forchi-title">Professionals and freelancers</div>
        <div class="forchi-desc">Personal branding, positioning, online visibility. Fully remote, for any industry.</div>
      </div>
      <div class="forchi-item reveal reveal-delay-3">
        <div class="forchi-ico">🌍</div>
        <div class="forchi-title">International brands</div>
        <div class="forchi-desc">Content in Italian, English, Spanish and French. No need to rely on external translators.</div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <div class="section-dark">
    <section class="section cta-section">
      <div class="cta-inner">
        <span class="eyebrow eyebrow-light reveal">Let's talk</span>
        <h2 class="sec-title-light reveal reveal-delay-1">Ready to start?</h2>
        <p class="cta-sub reveal reveal-delay-2">Get in touch for a custom quote or to figure out together which package suits you best.</p>
        <div class="cta-btns reveal reveal-delay-3">
          <a href="/en/contatti" class="btn btn-gold">Write to me</a>
          <a href="/en/servizi" class="btn btn-outline-light">All services</a>
        </div>
      </div>
    </section>
  </div>

</Layout>

<style>
.smm-hero {
  padding: clamp(48px, 6vw, 80px) clamp(20px, 5vw, 80px) clamp(32px, 4vw, 56px);
  background: var(--blue-pale);
}

.smm-hero-inner { max-width: 1200px; margin: 0 auto; }

.breadcrumb {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 12px;
  color: var(--blue-mid);
  margin-bottom: 20px;
}

.breadcrumb a { color: var(--blue); transition: opacity 0.2s; }
.breadcrumb a:hover { opacity: 0.7; }

.smm-hero h1 {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(40px, 6vw, 72px);
  font-weight: 300;
  color: var(--blue-dark);
  line-height: 1.1;
  margin-bottom: 16px;
}

.smm-hero h1 em { font-style: italic; color: var(--blue); }

.smm-hero-sub {
  font-size: 16px;
  color: var(--blue-mid);
  font-style: italic;
  font-family: 'Cormorant Garamond', serif;
}

.approach-section { padding-top: clamp(48px, 6vw, 80px); padding-bottom: clamp(48px, 6vw, 80px); }

.approach-grid {
  display: grid;
  grid-template-columns: 1fr 280px;
  gap: clamp(40px, 6vw, 80px);
  align-items: start;
}

.approach-text h2 { color: var(--blue-dark); margin-bottom: 16px; }
.approach-text p { font-size: 15px; color: var(--blue-mid); line-height: 1.8; margin-bottom: 24px; }

.approach-list { display: flex; flex-direction: column; gap: 12px; }

.approach-item {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  font-size: 14px;
  color: var(--blue-mid);
  line-height: 1.5;
}

.approach-check {
  color: var(--blue);
  font-weight: 500;
  flex-shrink: 0;
  margin-top: 1px;
}

.approach-side {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.approach-stat {
  padding: 20px;
  background: var(--blue-light);
  border-radius: var(--r-md);
  border: 0.5px solid rgba(43,79,216,0.15);
}

.stat-big {
  font-family: 'Cormorant Garamond', serif;
  font-size: 28px;
  font-weight: 400;
  color: var(--blue);
  margin-bottom: 4px;
}

.stat-label { font-size: 11px; color: var(--blue-mid); letter-spacing: 0.06em; }

.pricing-section { padding-top: clamp(48px, 6vw, 80px); padding-bottom: clamp(48px, 6vw, 80px); }

.pricing-sub {
  font-size: 14px;
  color: var(--azure);
  margin-bottom: 32px;
  font-style: italic;
  font-family: 'Cormorant Garamond', serif;
}

.pricing-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
  margin-bottom: 28px;
}

.pricing-card {
  background: rgba(43,79,216,0.1);
  border: 0.5px solid rgba(123,167,232,0.2);
  border-radius: var(--r-lg);
  padding: 28px;
  display: flex;
  flex-direction: column;
  gap: 16px;
  position: relative;
}

.pricing-card-featured {
  background: rgba(43,79,216,0.2);
  border-color: rgba(123,167,232,0.5);
}

.pricing-label-featured {
  position: absolute;
  top: -12px;
  left: 50%;
  transform: translateX(-50%);
  background: var(--gold);
  color: var(--gold-dark);
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 0.08em;
  padding: 4px 14px;
  border-radius: 20px;
  white-space: nowrap;
}

.pricing-label {
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--azure);
}

.pricing-price {
  display: flex;
  align-items: baseline;
  gap: 4px;
}

.p-val {
  font-family: 'Cormorant Garamond', serif;
  font-size: 42px;
  font-weight: 400;
  color: var(--white);
  line-height: 1;
}

.p-period { font-size: 14px; color: var(--azure); }

.pricing-desc { font-size: 13px; color: var(--azure); line-height: 1.6; }

.pricing-features {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 8px;
  flex: 1;
}

.pricing-features li {
  font-size: 13px;
  color: rgba(123,167,232,0.9);
  padding-left: 16px;
  position: relative;
  line-height: 1.5;
}

.pricing-features li::before {
  content: '→';
  position: absolute;
  left: 0;
  color: var(--blue);
  font-size: 12px;
}

.pricing-note {
  font-size: 11px;
  color: rgba(123,167,232,0.5);
  font-style: italic;
}

.pricing-btn { width: 100%; justify-content: center; margin-top: auto; }

.pricing-extra {
  background: rgba(43,79,216,0.08);
  border: 0.5px solid rgba(123,167,232,0.15);
  border-radius: var(--r-lg);
  padding: 24px;
  margin-bottom: 16px;
}

.extra-title {
  font-size: 12px;
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--azure);
  margin-bottom: 16px;
}

.extra-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}

.extra-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10px 14px;
  background: rgba(43,79,216,0.1);
  border-radius: var(--r-sm);
  gap: 12px;
}

.extra-name { font-size: 13px; color: var(--azure); }
.extra-price { font-size: 13px; color: var(--white); font-weight: 500; white-space: nowrap; }

.pricing-disclaimer {
  font-size: 11px;
  color: rgba(123,167,232,0.4);
  text-align: center;
  line-height: 1.6;
}

.forchi-section { padding-top: clamp(48px, 6vw, 80px); padding-bottom: clamp(48px, 6vw, 80px); }

.forchi-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
}

.forchi-item {
  background: var(--white);
  border: 0.5px solid rgba(43,79,216,0.12);
  border-radius: var(--r-lg);
  padding: 24px;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.forchi-item:hover {
  transform: translateY(-3px);
  box-shadow: 0 4px 20px rgba(43,79,216,0.08);
}

.forchi-ico { font-size: 28px; margin-bottom: 12px; }
.forchi-title { font-size: 15px; font-weight: 500; color: var(--blue-dark); margin-bottom: 8px; }
.forchi-desc { font-size: 13px; color: var(--blue-mid); line-height: 1.7; }

.cta-section { text-align: center; }
.cta-section .eyebrow { display: block; margin-bottom: 8px; }
.cta-section h2 { margin-bottom: 16px; }
.cta-sub { font-size: 15px; color: var(--azure); max-width: 480px; margin: 0 auto 32px; line-height: 1.75; }
.cta-btns { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }

@media (max-width: 1024px) {
  .pricing-grid { grid-template-columns: 1fr; max-width: 480px; margin-left: auto; margin-right: auto; }
  .forchi-grid { grid-template-columns: 1fr 1fr; }
}

@media (max-width: 768px) {
  .approach-grid { grid-template-columns: 1fr; }
  .approach-side { flex-direction: row; flex-wrap: wrap; }
  .approach-stat { flex: 1; min-width: 140px; }
  .extra-grid { grid-template-columns: 1fr; }
  .forchi-grid { grid-template-columns: 1fr; }
}
</style>
---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Federica Fanì — Social Media Manager, Developer, Photographer"
  description="Social media manager, developer, photographer, burnt out. The best projects? Born at the intersection of all four."
  lang="en"
>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-content">
      <div class="hero-left">
        <div class="hero-eyebrow reveal">
          <span class="eyebrow-line"></span>
          <span class="eyebrow">Social Media Manager · App Developer · Photographer · Rome</span>
        </div>

        <h1 class="hero-headline reveal reveal-delay-1">
          Piano and drums.<br>
          Vinyl and code.<br>
          <em>Opposites don't cancel each other out. They multiply.</em>
        </h1>

        <p class="hero-sub reveal reveal-delay-2">
          Social media manager, developer, photographer, burnt out.<br>The best projects? Born at the intersection of all four — even if the fourth might just be a side effect of the first three.
        </p>

        <div class="hero-ctas reveal reveal-delay-3">
          <a href="/en/services" class="btn btn-primary">Explore services</a>
          <a href="/en/portfolio" class="btn btn-outline">View portfolio</a>
        </div>

        <div class="hero-stats reveal reveal-delay-4">
          <div class="stat">
            <div class="stat-val">3+</div>
            <div class="stat-label">Years of experience</div>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <div class="stat-val">IT · EN · ES · FR</div>
            <div class="stat-label">Working languages</div>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <div class="stat-val">Rome</div>
            <div class="stat-label">And remote everywhere</div>
          </div>
        </div>
      </div>

      <div class="hero-right reveal reveal-delay-2">
        <div class="hero-img-wrap">
          <div class="hero-deco-circle"></div>
          <div class="hero-img">
            <img src="/images/foto_2.jpg" alt="Federica Fanì" loading="eager" style="object-position: center top;" />
          </div>
          <div class="hero-badge">
            <div class="badge-dot"></div>
            <div class="badge-text">
              <strong>Available for new projects</strong>
              <span>open to work</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES PREVIEW -->
  <div class="section-dark">
    <section class="section">
      <div class="sec-header">
        <div class="sec-header-left">
          <span class="eyebrow eyebrow-light reveal">What I do</span>
          <h2 class="sec-title-light reveal reveal-delay-1">Services</h2>
        </div>
        <a href="/en/services" class="sec-link sec-link-light reveal">See all <span>→</span></a>
      </div>

      <div class="svc-grid">
        <a href="/en/services/smm" class="svc-card reveal">
          <div class="svc-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
          </div>
          <div class="svc-name">Social Media Management</div>
          <div class="svc-desc">Strategy, content, photography. Real work, done with care.</div>
          <span class="svc-arrow">→</span>
        </a>

        <a href="/en/services/app-dev" class="svc-card reveal reveal-delay-1">
          <div class="svc-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
          </div>
          <div class="svc-name">App & SaaS Development</div>
          <div class="svc-desc">Concrete things, built with care.</div>
          <span class="svc-arrow">→</span>
        </a>

        <div class="svc-card svc-soon reveal reveal-delay-2">
          <div class="svc-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <div class="svc-name">Data Privacy & GRC</div>
          <div class="svc-desc">Digital compliance and risk management.</div>
          <span class="soon-badge">Coming soon</span>
        </div>

        <div class="svc-card svc-soon reveal reveal-delay-3">
          <div class="svc-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          </div>
          <div class="svc-name">Project Management</div>
          <div class="svc-desc">Process coordination and digital project management.</div>
          <span class="soon-badge">Coming soon</span>
        </div>
      </div>
    </section>
  </div>

  <!-- ABOUT PREVIEW -->
  <section class="section about-preview">
    <div class="about-grid">
      <div class="about-text">
        <span class="eyebrow reveal">About me</span>
        <h2 class="reveal reveal-delay-1">Pescara, Macerata, Rome. Piano, drums, vinyl, code.</h2>
        <p class="reveal reveal-delay-2">The long version is here.</p>
        <a href="/en/about" class="btn btn-outline reveal reveal-delay-3">Find out more</a>
      </div>
      <div class="about-facts reveal reveal-delay-1">
        <div class="fact-item">
          <span class="fact-num">19</span>
          <span class="fact-label">Tattoos, mostly music-related</span>
        </div>
        <div class="fact-item">
          <span class="fact-num">4</span>
          <span class="fact-label">Languages spoken</span>
        </div>
        <div class="fact-item">
          <span class="fact-num">∞</span>
          <span class="fact-label">Records still to collect</span>
        </div>
      </div>
    </div>
  </section>

  <!-- EDUCATION PREVIEW -->
  <div class="section-dark">
    <section class="section">
      <div class="sec-header">
        <div class="sec-header-left">
          <span class="eyebrow eyebrow-light reveal">Education</span>
          <h2 class="sec-title-light reveal reveal-delay-1">Certifications</h2>
        </div>
        <a href="/en/education" class="sec-link sec-link-light reveal">See all <span>→</span></a>
      </div>
      <p class="cert-preview-text reveal reveal-delay-1">What I know how to do, I have a piece of paper to prove it. Most of the time.</p>
      <div class="cert-pills reveal reveal-delay-2">
        <span class="cert-pill">Learnn</span>
        <span class="cert-pill">Carriere.it</span>
        <span class="cert-pill">Coursera</span>
        <span class="cert-pill">Google Skillshop</span>
        <span class="cert-pill">Meta Blueprint</span>
        <span class="cert-pill">HubSpot Academy</span>
      </div>
    </section>
  </div>

  <!-- GALLERY PREVIEW -->
  <section class="section gallery-preview">
    <div class="sec-header">
      <div class="sec-header-left">
        <span class="eyebrow reveal">Gallery</span>
        <h2 class="reveal reveal-delay-1">Photography</h2>
      </div>
      <a href="/en/gallery" class="sec-link reveal">See all <span>→</span></a>
    </div>
    <p class="gallery-sub reveal reveal-delay-1">Concerts, clubs, people. Shot on a Nikon with a lot of patience for the right light.</p>
    <div class="gallery-grid reveal reveal-delay-2">
      <div class="gallery-cell gallery-cell-large">
        <img src="/foto/eventi_quartierevino_01.jpg" alt="Quartiere Vino — Pigneto" loading="lazy" />
      </div>
      <div class="gallery-cell">
        <img src="/foto/locale_magnebevo_02.jpg" alt="Magnebevo — Pigneto" loading="lazy" />
      </div>
      <div class="gallery-cell">
        <img src="/foto/eventi_quartierevino_05.jpg" alt="Quartiere Vino — Pigneto" loading="lazy" />
      </div>
      <div class="gallery-cell">
        <img src="/foto/locale_magnebevo_06.jpg" alt="Magnebevo — Pigneto" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- CONTACT PREVIEW -->
  <div class="section-dark">
    <section class="section contact-preview">
      <div class="contact-inner">
        <span class="eyebrow eyebrow-light reveal">Let's talk</span>
        <h2 class="sec-title-light reveal reveal-delay-1">Got a project in mind?</h2>
        <p class="contact-sub reveal reveal-delay-2">Messages don't bite. Write to me for collaborations, projects, or just to recommend an album.</p>
        <a href="/en/contact" class="btn btn-gold reveal reveal-delay-3">Get in touch</a>
      </div>
    </section>
  </div>

</Layout>

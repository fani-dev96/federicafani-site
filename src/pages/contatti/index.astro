---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Contatti — Federica Fanì"
  description="Non mordono, i messaggi. Scrivimi per collaborazioni, progetti, o anche solo per consigliarmi un disco."
>

  <!-- HERO -->
  <section class="contact-hero">
    <div class="contact-hero-inner">
      <div class="hero-eyebrow reveal">
        <span class="eyebrow-line"></span>
        <span class="eyebrow">Parliamo</span>
      </div>
      <h1 class="reveal reveal-delay-1">Contatti</h1>
      <p class="contact-hero-sub reveal reveal-delay-2">
        Non mordono, i messaggi. Scrivimi per collaborazioni, progetti, o anche solo per consigliarmi un disco.
      </p>
    </div>
  </section>

  <!-- CONTACT SPLIT -->
  <section class="section contact-section">
    <div class="contact-grid">

      <!-- INFO -->
      <div class="contact-info">
        <span class="eyebrow reveal">Dove trovarmi</span>

        <div class="info-items">
          <a href="mailto:federica.fani96@gmail.com" class="info-item reveal reveal-delay-1">
            <div class="info-ico">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <div class="info-text">
              <div class="info-label">Email</div>
              <div class="info-val">federica.fani96@gmail.com</div>
            </div>
          </a>

          <a href="tel:+393762951512" class="info-item reveal reveal-delay-2">
            <div class="info-ico">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.56 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <div class="info-text">
              <div class="info-label">Telefono</div>
              <div class="info-val">+39 376 295 1512</div>
            </div>
          </a>

          <a href="https://instagram.com/fedefany" target="_blank" rel="noopener" class="info-item reveal reveal-delay-3">
            <div class="info-ico">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
            </div>
            <div class="info-text">
              <div class="info-label">Instagram</div>
              <div class="info-val">@fedefany</div>
            </div>
          </a>

          <a href="https://github.com/fani-dev96" target="_blank" rel="noopener" class="info-item reveal reveal-delay-3">
            <div class="info-ico">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
            </div>
            <div class="info-text">
              <div class="info-label">GitHub</div>
              <div class="info-val">fani-dev96</div>
            </div>
          </a>

          <a href="https://linkedin.com/in/federica-fani" target="_blank" rel="noopener" class="info-item reveal reveal-delay-3">
            <div class="info-ico">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
            </div>
            <div class="info-text">
              <div class="info-label">LinkedIn</div>
              <div class="info-val">federica-fani</div>
            </div>
          </a>
        </div>

        <div class="availability reveal">
          <div class="avail-dot"></div>
          <div class="avail-text">
            <strong>Disponibile per nuovi progetti</strong>
            <span>Rispondo entro 24–48 ore</span>
          </div>
        </div>
      </div>

      <!-- FORM -->
      <div class="contact-form-wrap reveal reveal-delay-1">
        <form class="contact-form" id="contactForm" name="contact" method="POST" data-netlify="true" action="/contatti/grazie">
          <div class="form-group">
            <label for="nome">Nome</label>
            <input type="text" id="nome" name="nome" placeholder="Il tuo nome" required />
          </div>

          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" placeholder="la-tua@email.com" required />
          </div>

          <div class="form-group">
            <label for="servizio">Mi interessa</label>
            <select id="servizio" name="servizio">
              <option value="">Seleziona un servizio</option>
              <option value="smm">Social Media Management</option>
              <option value="app-dev">App & SaaS Development</option>
              <option value="entrambi">Entrambi</option>
              <option value="altro">Altro / solo per conoscersi</option>
            </select>
          </div>

          <div class="form-group">
            <label for="messaggio">Messaggio</label>
            <textarea id="messaggio" name="messaggio" rows="5" placeholder="Raccontami del tuo progetto, o consigliami un disco..." required></textarea>
          </div>

          <button type="submit" class="btn btn-primary form-submit">Invia messaggio</button>
        </form>
      </div>

    </div>
  </section>

  <!-- NOTE -->
  <div class="section-dark">
    <section class="section faq-section">
      <div class="sec-header">
        <div class="sec-header-left">
          <span class="eyebrow eyebrow-light reveal">Prima di scrivere</span>
          <h2 class="sec-title-light reveal reveal-delay-1">Domande frequenti</h2>
        </div>
      </div>

      <div class="faq-grid">
        <div class="faq-item reveal">
          <div class="faq-q">Lavori solo a Roma?</div>
          <div class="faq-a">Per SMM e sviluppo app lavoro completamente da remoto, quindi ovunque. Per fotografia e riprese opero principalmente nella zona del Pigneto e Roma Est.</div>
        </div>

        <div class="faq-item reveal reveal-delay-1">
          <div class="faq-q">Quanto tempo prima devo contattarti?</div>
          <div class="faq-a">Prima è meglio. Per nuovi clienti SMM ho solitamente disponibilità entro 2–4 settimane. Per progetti di sviluppo dipende dalla complessità.</div>
        </div>

        <div class="faq-item reveal reveal-delay-2">
          <div class="faq-q">Fai preventivi gratuiti?</div>
          <div class="faq-a">Sì. Per i pacchetti SMM i prezzi sono già indicativi sul sito. Per progetti di sviluppo app la prima analisi di fattibilità è sempre gratuita.</div>
        </div>

        <div class="faq-item reveal reveal-delay-3">
          <div class="faq-q">Hai una durata minima contrattuale?</div>
          <div class="faq-a">Per l'SMM chiedo un minimo di 3 mesi: serve tempo per vedere risultati concreti. Per i progetti di sviluppo dipende dall'accordo.</div>
        </div>
      </div>
    </section>
  </div>

</Layout>

<style>
/* HERO */
.contact-hero {
  padding: clamp(48px, 6vw, 80px) clamp(20px, 5vw, 80px) clamp(32px, 4vw, 56px);
  background: var(--blue-pale);
}

.contact-hero-inner { max-width: 1200px; margin: 0 auto; }

.hero-eyebrow {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 16px;
}

.eyebrow-line {
  width: 32px;
  height: 1px;
  background: var(--blue);
  flex-shrink: 0;
}

.contact-hero h1 {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(40px, 6vw, 72px);
  font-weight: 300;
  color: var(--blue-dark);
  line-height: 1.1;
  margin-bottom: 16px;
}

.contact-hero-sub {
  font-size: 16px;
  color: var(--blue-mid);
  font-style: italic;
  font-family: 'Cormorant Garamond', serif;
}

/* CONTACT SECTION */
.contact-section {
  padding-top: clamp(48px, 6vw, 80px);
  padding-bottom: clamp(48px, 6vw, 80px);
}

.contact-grid {
  display: grid;
  grid-template-columns: 380px 1fr;
  gap: clamp(40px, 6vw, 80px);
  align-items: start;
}

/* INFO */
.contact-info { display: flex; flex-direction: column; gap: 28px; }
.contact-info .eyebrow { display: block; }

.info-items { display: flex; flex-direction: column; gap: 4px; }

.info-item {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 16px;
  border-radius: var(--r-md);
  text-decoration: none;
  transition: background 0.2s ease;
}

.info-item:hover { background: var(--blue-light); }

.info-ico {
  width: 40px;
  height: 40px;
  border-radius: var(--r-sm);
  background: var(--blue-light);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--blue);
  flex-shrink: 0;
  transition: background 0.2s ease;
}

.info-item:hover .info-ico { background: var(--blue); color: var(--white); }

.info-label {
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--blue-mid);
  margin-bottom: 2px;
}

.info-val {
  font-size: 14px;
  color: var(--blue-dark);
  font-weight: 400;
}

.availability {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 16px 20px;
  background: #f0fdf4;
  border: 0.5px solid #86efac;
  border-radius: var(--r-md);
}

.avail-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: #16a34a;
  flex-shrink: 0;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.avail-text strong {
  display: block;
  font-size: 13px;
  font-weight: 500;
  color: #15803d;
  margin-bottom: 2px;
}

.avail-text span { font-size: 12px; color: #16a34a; }

/* FORM */
.contact-form-wrap {
  background: var(--white);
  border: 0.5px solid rgba(43,79,216,0.12);
  border-radius: var(--r-lg);
  padding: 36px;
}

.contact-form { display: flex; flex-direction: column; gap: 20px; }

.form-group { display: flex; flex-direction: column; gap: 6px; }

.form-group label {
  font-size: 12px;
  font-weight: 500;
  letter-spacing: 0.06em;
  color: var(--blue-mid);
}

.form-group input,
.form-group select,
.form-group textarea {
  font-family: 'DM Sans', sans-serif;
  font-size: 14px;
  font-weight: 300;
  color: var(--blue-dark);
  background: var(--blue-pale);
  border: 0.5px solid rgba(43,79,216,0.2);
  border-radius: var(--r-sm);
  padding: 12px 16px;
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
  outline: none;
  width: 100%;
}

.form-group input:focus,
.form-group select:focus,
.form-group textarea:focus {
  border-color: var(--blue);
  box-shadow: 0 0 0 3px rgba(43,79,216,0.1);
}

.form-group textarea { resize: vertical; min-height: 120px; }

.form-group select { cursor: pointer; }

.form-submit {
  width: 100%;
  justify-content: center;
  padding: 14px;
  font-size: 14px;
}

/* FAQ */
.faq-section { padding-top: clamp(48px, 6vw, 80px); padding-bottom: clamp(48px, 6vw, 80px); }

.faq-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}

.faq-item {
  background: rgba(43,79,216,0.1);
  border: 0.5px solid rgba(123,167,232,0.2);
  border-radius: var(--r-lg);
  padding: 24px;
}

.faq-q {
  font-size: 15px;
  font-weight: 500;
  color: var(--white);
  margin-bottom: 10px;
  font-family: 'Cormorant Garamond', serif;
}

.faq-a {
  font-size: 13px;
  color: var(--azure);
  line-height: 1.75;
}

/* RESPONSIVE */
@media (max-width: 900px) {
  .contact-grid { grid-template-columns: 1fr; }
  .faq-grid { grid-template-columns: 1fr; }
}

@media (max-width: 640px) {
  .contact-form-wrap { padding: 24px; }
}
</style>

---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Federica Fanì — Social Media Manager, Développeuse, Photographe"
  description="Social media manager, développeuse, photographe, épuisée. Les meilleurs projets ? Nés à l'intersection de ces quatre choses."
  lang="fr"
>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-content">
      <div class="hero-left">
        <div class="hero-eyebrow reveal">
          <span class="eyebrow-line"></span>
          <span class="eyebrow">Social Media Manager · App Developer · Photographe · Rome</span>
        </div>

        <h1 class="hero-headline reveal reveal-delay-1">
          Piano et batterie.<br>
          Vinyles et code.<br>
          <em>Les contraires ne s'excluent pas. Ils se multiplient.</em>
        </h1>

        <p class="hero-sub reveal reveal-delay-2">
          Social media manager, développeuse, photographe, épuisée.<br>Les meilleurs projets ? Nés à l'intersection de ces 4 choses — même si la quatrième n'est peut-être que le résultat des trois premières.
        </p>

        <div class="hero-ctas reveal reveal-delay-3">
          <a href="/fr/servizi" class="btn btn-primary">Voir les services</a>
          <a href="/fr/portfolio" class="btn btn-outline">Voir le portfolio</a>
        </div>

        <div class="hero-stats reveal reveal-delay-4">
          <div class="stat">
            <div class="stat-val">3+</div>
            <div class="stat-label">Ans d'expérience</div>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <div class="stat-val">IT · EN · ES · FR</div>
            <div class="stat-label">Langues de travail</div>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <div class="stat-val">Rome</div>
            <div class="stat-label">Et à distance partout</div>
          </div>
        </div>
      </div>

      <div class="hero-right reveal reveal-delay-2">
        <div class="hero-img-wrap">
          <div class="hero-deco-circle"></div>
          <div class="hero-img">
            <img src="/images/foto_2.jpg" alt="Federica Fanì" loading="eager" style="object-position: center top;" />
          </div>
          <div class="hero-badge">
            <div class="badge-dot"></div>
            <div class="badge-text">
              <strong>Disponible pour de nouveaux projets</strong>
              <span>open to work</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES PREVIEW -->
  <div class="section-dark">
    <section class="section">
      <div class="sec-header">
        <div class="sec-header-left">
          <span class="eyebrow eyebrow-light reveal">Ce que je fais</span>
          <h2 class="sec-title-light reveal reveal-delay-1">Services</h2>
        </div>
        <a href="/fr/servizi" class="sec-link sec-link-light reveal">Voir tout <span>→</span></a>
      </div>

      <div class="svc-grid">
        <a href="/fr/servizi/smm" class="svc-card reveal">
          <div class="svc-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
          </div>
          <div class="svc-name">Social Media Management</div>
          <div class="svc-desc">Stratégie, contenu, photographie. Du travail concret, fait avec soin.</div>
          <span class="svc-arrow">→</span>
        </a>

        <a href="/fr/servizi/app-dev" class="svc-card reveal reveal-delay-1">
          <div class="svc-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
          </div>
          <div class="svc-name">App & SaaS Development</div>
          <div class="svc-desc">Des choses concrètes, faites avec soin.</div>
          <span class="svc-arrow">→</span>
        </a>

        <div class="svc-card svc-soon reveal reveal-delay-2">
          <div class="svc-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <div class="svc-name">Data Privacy & GRC</div>
          <div class="svc-desc">Conformité numérique et gestion des risques.</div>
          <span class="soon-badge">Bientôt disponible</span>
        </div>

        <div class="svc-card svc-soon reveal reveal-delay-3">
          <div class="svc-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          </div>
          <div class="svc-name">Project Management</div>
          <div class="svc-desc">Coordination de processus et gestion de projets numériques.</div>
          <span class="soon-badge">Bientôt disponible</span>
        </div>
      </div>
    </section>
  </div>

  <!-- À PROPOS PREVIEW -->
  <section class="section about-preview">
    <div class="about-grid">
      <div class="about-text">
        <span class="eyebrow reveal">À propos</span>
        <h2 class="reveal reveal-delay-1">Pescara, Macerata, Rome. Piano, batterie, vinyles, code.</h2>
        <p class="reveal reveal-delay-2">La version longue est ici.</p>
        <a href="/fr/chi-sono" class="btn btn-outline reveal reveal-delay-3">En savoir plus</a>
      </div>
      <div class="about-facts reveal reveal-delay-1">
        <div class="fact-item">
          <span class="fact-num">19</span>
          <span class="fact-label">Tatouages, surtout musicaux</span>
        </div>
        <div class="fact-item">
          <span class="fact-num">4</span>
          <span class="fact-label">Langues parlées</span>
        </div>
        <div class="fact-item">
          <span class="fact-num">∞</span>
          <span class="fact-label">Vinyles encore à collectionner</span>
        </div>
      </div>
    </div>
  </section>

  <!-- FORMATION PREVIEW -->
  <div class="section-dark">
    <section class="section">
      <div class="sec-header">
        <div class="sec-header-left">
          <span class="eyebrow eyebrow-light reveal">Formation</span>
          <h2 class="sec-title-light reveal reveal-delay-1">Certifications</h2>
        </div>
        <a href="/fr/formazione" class="sec-link sec-link-light reveal">Voir tout <span>→</span></a>
      </div>
      <p class="cert-preview-text reveal reveal-delay-1">Ce que je sais faire, j'ai un papier pour le prouver. Presque toujours.</p>
      <div class="cert-pills reveal reveal-delay-2">
        <span class="cert-pill">Learnn</span>
        <span class="cert-pill">Carriere.it</span>
        <span class="cert-pill">Coursera</span>
        <span class="cert-pill">Google Skillshop</span>
        <span class="cert-pill">Meta Blueprint</span>
        <span class="cert-pill">HubSpot Academy</span>
      </div>
    </section>
  </div>

  <!-- GALERIE PREVIEW -->
  <section class="section gallery-preview">
    <div class="sec-header">
      <div class="sec-header-left">
        <span class="eyebrow reveal">Galerie</span>
        <h2 class="reveal reveal-delay-1">Photographie</h2>
      </div>
      <a href="/fr/galleria" class="sec-link reveal">Voir tout <span>→</span></a>
    </div>
    <p class="gallery-sub reveal reveal-delay-1">Concerts, clubs, personnes. Prises avec un Nikon et beaucoup de patience pour trouver la bonne lumière.</p>
    <div class="gallery-grid reveal reveal-delay-2">
      <div class="gallery-cell gallery-cell-large">
        <img src="/foto/eventi_quartierevino_01.jpg" alt="Quartiere Vino — Pigneto" loading="lazy" />
      </div>
      <div class="gallery-cell">
        <img src="/foto/locale_magnebevo_02.jpg" alt="Magnebevo — Pigneto" loading="lazy" />
      </div>
      <div class="gallery-cell">
        <img src="/foto/eventi_quartierevino_05.jpg" alt="Quartiere Vino — Pigneto" loading="lazy" />
      </div>
      <div class="gallery-cell">
        <img src="/foto/locale_magnebevo_06.jpg" alt="Magnebevo — Pigneto" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- CONTACT PREVIEW -->
  <div class="section-dark">
    <section class="section contact-preview">
      <div class="contact-inner">
        <span class="eyebrow eyebrow-light reveal">Parlons-en</span>
        <h2 class="sec-title-light reveal reveal-delay-1">Vous avez un projet en tête ?</h2>
        <p class="contact-sub reveal reveal-delay-2">Les messages ne mordent pas. Écrivez-moi pour des collaborations, des projets, ou juste pour me recommander un disque.</p>
        <a href="/fr/contatti" class="btn btn-gold reveal reveal-delay-3">Me contacter</a>
      </div>
    </section>
  </div>

</Layout>

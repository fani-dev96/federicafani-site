---
const { lang = 'it' } = Astro.props;
const year = new Date().getFullYear();
const prefix = lang === 'it' ? '' : `/${lang}`;
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-left">
      <a href={`${prefix}/`} class="footer-logo">Federica <span>Fanì</span></a>
      <p class="footer-tagline">Pianoforte e batteria. Vinili e codice.</p>
    </div>

    <nav class="footer-nav">
      <a href={`${prefix}/chi-sono`}>Chi sono</a>
      <a href={`${prefix}/servizi/smm`}>Servizi</a>
      <a href={`${prefix}/formazione`}>Formazione</a>
      <a href={`${prefix}/galleria`}>Galleria</a>
      <a href={`${prefix}/portfolio`}>Portfolio</a>
      <a href={`${prefix}/contatti`}>Contatti</a>
    </nav>

    <div class="footer-right">
      <div class="footer-socials">
        <a href="https://instagram.com/fedefany" target="_blank" rel="noopener" aria-label="Instagram">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
        </a>
        <a href="https://github.com/fani-dev96" target="_blank" rel="noopener" aria-label="GitHub">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
        </a>
        <a href="mailto:federica.fani96@gmail.com" aria-label="Email">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        </a>
      </div>
      <div class="footer-langs">
        <a href="/" class={lang === 'it' ? 'active' : ''}>IT</a>
        <a href="/en/" class={lang === 'en' ? 'active' : ''}>EN</a>
        <a href="/es/" class={lang === 'es' ? 'active' : ''}>ES</a>
      </div>
    </div>
  </div>
  <div class="footer-bottom">
    <span>© {year} Federica Fanì · federicafani.com</span>
    <span>Roma, Italia</span>
  </div>
</footer>

<style>
.footer {
  background: var(--blue-dark);
  padding: 56px clamp(20px, 5vw, 80px) 24px;
}

.footer-inner {
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  gap: 48px;
  align-items: start;
  padding-bottom: 40px;
  border-bottom: 0.5px solid rgba(123,167,232,0.2);
}

.footer-logo {
  font-family: 'DM Sans', sans-serif;
  font-size: 18px;
  font-weight: 400;
  color: var(--white);
  display: block;
  margin-bottom: 8px;
}

.footer-logo span { color: var(--azure); }

.footer-tagline {
  font-size: 12px;
  color: rgba(123,167,232,0.5);
  font-style: italic;
  font-family: 'Cormorant Garamond', serif;
}

.footer-nav {
  display: flex;
  flex-direction: column;
  gap: 10px;
  align-items: center;
}

.footer-nav a {
  font-size: 13px;
  color: rgba(123,167,232,0.7);
  transition: color 0.2s ease;
}

.footer-nav a:hover { color: var(--white); }

.footer-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 16px;
}

.footer-socials {
  display: flex;
  gap: 12px;
}

.footer-socials a {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  border: 0.5px solid rgba(123,167,232,0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--azure);
  transition: all 0.2s ease;
}

.footer-socials a:hover {
  border-color: var(--azure);
  color: var(--white);
  background: rgba(123,167,232,0.1);
}

.footer-langs {
  display: flex;
  gap: 4px;
}

.footer-langs a {
  font-size: 11px;
  font-weight: 500;
  padding: 4px 8px;
  border-radius: 5px;
  color: rgba(123,167,232,0.5);
  transition: all 0.15s ease;
}

.footer-langs a:hover { color: var(--azure); }
.footer-langs a.active { color: var(--gold); }

.footer-bottom {
  max-width: 1200px;
  margin: 24px auto 0;
  display: flex;
  justify-content: space-between;
  font-size: 11px;
  color: rgba(123,167,232,0.3);
}

@media (max-width: 768px) {
  .footer-inner {
    grid-template-columns: 1fr;
    gap: 32px;
  }

  .footer-right { align-items: flex-start; }
  .footer-bottom { flex-direction: column; gap: 4px; }
}
</style>
